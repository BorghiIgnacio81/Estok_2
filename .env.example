# =============================================================================
# .env.example - Estok en Coolify
# Copia este archivo como .env y completa los valores
# Luego carga estas variables en el dashboard de Coolify
# =============================================================================

# =============================================================================
# DJANGO
# =============================================================================
DJANGO_SECRET_KEY=genera-una-clave-unica-con-python-c-manage.py-shell
DEBUG=False

# =============================================================================
# BASE DE DATOS - PostgreSQL 17 (Coolify Resource)
# Resource ID: postgresql-database-cagtcifjoy8ydxugg4bkdll1
# Se usan variables DB_* individuales (NO DATABASE_URL)
# =============================================================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=estok_db
DB_USER=postgres
DB_PASSWORD=tu_contraseña_segura_aqui
DB_HOST=cagtcifjoy8ydxugg4bkdll1
DB_PORT=5432

# =============================================================================
# JWT (SimpleJWT)
# =============================================================================
JWT_SECRET=genera-un-secreto-unico-para-jwt

# =============================================================================
# IA HÍBRIDA - LM Studio (RX 9060 XT en tu PC local)
# AI_API_ENDPOINT debe apuntar a la IP de tu PC en la red local
# Coolify en Hetzner se conectará a tu PC vía Internet o VPN
# =============================================================================
AI_API_ENDPOINT=http://192.168.1.100:1234/v1
