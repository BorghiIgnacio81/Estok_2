  // INICIALIZACIÓN DE LA UI
  // Llamar después de que todas las funciones estén definidas para evitar
  // errores de TDZ (Temporal Dead Zone) al minificar con Astro.
  // ===========================================================================
  function initUI() {
    updateAuthUI();
    updateEstokUIMobile();
    updateEstokBarMobile();
  }

  if (document.readyState === 'complete') {
    initUI();
  } else {
    window.addEventListener('load', () => {
      initUI();
    });
  }

</script>
