---
// =============================================================================
// LAYOUT BASE - Estok Inventory System
// Estructura HTML principal con Tailwind CSS y meta tags
// =============================================================================

// Importar estilos globales (Astro los procesa y los pone en /assets/ con hash)
import '../styles/global.css';
import ChatModal from '../components/ChatModal.astro';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Estok - Sistema de Inventario', description = 'Sistema de gestión de inventario personal con herencia multi-tabla' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#8B4513" />

    <title>{title}</title>

    <!-- Favicon (cache buster v2) -->
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="mask-icon" href="/favicon.svg?v=2" color="#8B4513" />
    <link rel="shortcut icon" href="/favicon.png?v=2" type="image/png" />

    <!-- Fuente Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Cropper.js CSS + JS (para editor de fotos) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js" defer></script>

    <!-- PWA: Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Estok" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

  </head>
  <body>
    <!-- Barra de navegación -->
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Fila superior: Logo + Acciones derecha -->
        <div class="flex items-center justify-between h-16">
          <!-- Logo y marca -->
          <div class="flex items-center min-w-0 flex-shrink">
            <a href="/" class="flex items-center space-x-2 flex-shrink-0">
              <img src="/favicon.png" alt="Estok" class="h-10 w-10 sm:h-16 sm:w-16 object-cover" />
              <span class="text-xl sm:text-2xl font-bold text-blue-700">Estok</span>
            </a>
            <!-- Nombre del Estok (mobile: debajo del logo, desktop: inline) -->
            <div id="estokNombreMobile" class="ml-2 truncate hidden">
              <span class="text-xs font-semibold text-blue-800 truncate max-w-[120px] sm:max-w-[200px] block"></span>
              <span id="estokRoleBadgeMobile" class="text-[10px] px-1 py-0.5 rounded-full bg-blue-100 text-blue-700 font-medium"></span>
            </div>
          </div>

          <!-- Acciones derecha (siempre visibles) -->
          <div class="flex items-center space-x-1 sm:space-x-3">
            <!-- Botón Instalar App (PWA) -->
            <button id="installAppBtn"
              class="p-2 rounded-lg text-blue-700 hover:text-blue-900 hover:bg-blue-50 transition-base relative group"
              title="Instalar Estok en tu dispositivo">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span class="absolute -top-8 left-1/2 -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
                Descargar App
              </span>
            </button>
            <!-- Dark Mode Toggle -->
            <button id="darkModeToggle" class="p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-base" title="Cambiar tema">
              <svg id="sunIcon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              <svg id="moonIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </button>
            <!-- Botón menú hamburguesa (mobile) -->
            <button id="mobileMenuBtn" class="md:hidden p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-base" title="Menú">
              <svg id="menuIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              <svg id="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
            <div id="authSection" class="hidden flex items-center gap-1 sm:gap-3">
              <span id="userName" class="text-xs sm:text-sm text-gray-600 font-medium truncate max-w-[80px] sm:max-w-[150px]"></span>
              <button
                id="logoutBtn"
                class="text-xs sm:text-sm text-red-600 hover:text-red-700 transition-base font-medium whitespace-nowrap"
              >
                Cerrar Sesión
              </button>
            </div>
            <a id="loginLink" href="/login" class="text-sm text-gray-600 hover:text-blue-700 transition-base">
              Iniciar Sesión
            </a>
          </div>
        </div>

        <!-- Fila inferior: Nombre del Estok en mobile (debajo del logo) -->
        <div id="estokSectionMobile" class="hidden md:hidden pb-2">
          <div class="flex items-center gap-2">
            <!-- Dropdown de Estoks compacto -->
            <div id="estokDropdownMobile" class="relative flex-1">
              <button id="estokDropdownBtnMobile"
                class="flex items-center gap-1.5 w-full px-2 py-1.5 bg-blue-50 rounded-lg border border-blue-100 hover:bg-blue-100 transition-base cursor-pointer text-left"
                title="Cambiar de Estok">
                <svg class="w-3.5 h-3.5 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                <span id="estokNombreMobileBtn" class="text-sm font-semibold text-blue-800 truncate flex-1"></span>
                <span id="estokRoleBadgeMobileBtn" class="text-[10px] px-1.5 py-0.5 rounded-full bg-blue-200 text-blue-800 font-medium flex-shrink-0"></span>
                <svg class="w-3 h-3 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <!-- Menú desplegable mobile -->
              <div id="estokDropdownMenuMobile"
                class="hidden absolute top-full left-0 mt-1 w-64 bg-white rounded-xl shadow-xl border border-gray-200 py-1 z-50 overflow-hidden">
                <div class="px-3 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider border-b border-gray-100">
                  Mis Estoks
                </div>
                <div id="estokDropdownListMobile" class="max-h-60 overflow-y-auto">
                  <!-- Se llena dinámicamente -->
                </div>
                <div class="border-t border-gray-100 px-2 py-1">
                  <a href="/estoks"
                    class="flex items-center gap-2 px-3 py-2 text-sm text-blue-700 hover:bg-blue-50 rounded-lg transition-base font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    Gestionar Estoks
                  </a>
                </div>
              </div>
            </div>
            <button id="invitarBtnMobile"
              class="hidden px-2 py-1.5 text-xs font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg transition-base shadow-sm whitespace-nowrap"
              title="Invitar miembros al Estok">
              Invitar
            </button>
          </div>
        </div>

        <!-- Menú móvil desplegable (navegación) -->
        <div id="mobileNavMenu" class="hidden md:hidden border-t border-gray-200 pb-3 pt-2">
          <div class="flex flex-col space-y-1">
            <a href="/" class="px-3 py-2 text-sm text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-base font-medium">
              Dashboard
            </a>
            <a href="/objetos" class="px-3 py-2 text-sm text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-base font-medium">
              Objetos
            </a>
            <a href="/ubicaciones" class="px-3 py-2 text-sm text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-base font-medium">
              Ubicaciones
            </a>
            <a href="/contenedores" class="px-3 py-2 text-sm text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-base font-medium">
              Contenedores
            </a>
          </div>
        </div>

        <!-- Navegación principal desktop -->
        <div class="hidden md:flex items-center justify-between pb-2">
          <div class="flex items-center space-x-6">
            <a href="/" class="text-gray-600 hover:text-blue-700 transition-base font-medium">
              Dashboard
            </a>
            <a href="/objetos" class="text-gray-600 hover:text-blue-700 transition-base font-medium">
              Objetos
            </a>
            <a href="/ubicaciones" class="text-gray-600 hover:text-blue-700 transition-base font-medium">
              Ubicaciones
            </a>
            <a href="/contenedores" class="text-gray-600 hover:text-blue-700 transition-base font-medium">
              Contenedores
            </a>
          </div>
          <!-- Estok activo + Selector de Estoks + Invitar (desktop) -->
          <div id="estokSection" class="hidden flex items-center space-x-3">
            <!-- Dropdown de Estoks -->
            <div id="estokDropdown" class="relative">
              <button id="estokDropdownBtn"
                class="flex items-center gap-2 px-3 py-1.5 bg-blue-50 rounded-lg border border-blue-100 hover:bg-blue-100 transition-base cursor-pointer"
                title="Cambiar de Estok">
                <svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                <span id="estokNombre" class="text-sm font-semibold text-blue-800"></span>
                <span id="estokRoleBadge" class="text-xs px-1.5 py-0.5 rounded-full bg-blue-200 text-blue-800 font-medium"></span>
                <svg class="w-3 h-3 text-blue-500 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <!-- Menú desplegable -->
              <div id="estokDropdownMenu"
                class="hidden absolute top-full left-0 mt-1 w-64 bg-white rounded-xl shadow-xl border border-gray-200 py-1 z-50 overflow-hidden">
                <div class="px-3 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider border-b border-gray-100">
                  Mis Estoks
                </div>
                <div id="estokDropdownList" class="max-h-60 overflow-y-auto">
                  <!-- Se llena dinámicamente -->
                </div>
                <div class="border-t border-gray-100 px-2 py-1">
                  <a href="/estoks"
                    class="flex items-center gap-2 px-3 py-2 text-sm text-blue-700 hover:bg-blue-50 rounded-lg transition-base font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    Gestionar Estoks
                  </a>
                </div>
              </div>
            </div>
            <button id="invitarBtn"
              class="hidden px-3 py-1.5 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg transition-base shadow-sm"
              title="Invitar miembros al Estok">
              <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Invitar
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Barra de Estok activo (solo mobile) -->
    <div id="estokBarMobile" class="md:hidden hidden bg-blue-50 border-b border-blue-100">
      <div class="max-w-7xl mx-auto px-4 py-1.5">
        <div class="flex items-center justify-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          <span id="estokBarNombre" class="text-xs font-semibold text-blue-800 truncate max-w-[200px]"></span>
          <span id="estokBarRoleBadge" class="text-[10px] px-1.5 py-0.5 rounded-full bg-blue-200 text-blue-800 font-medium"></span>
        </div>
      </div>
    </div>

    <!-- Toast Container Global -->
    <div id="toastContainer" class="fixed top-4 right-4 z-[9999] flex flex-col gap-2 pointer-events-none"></div>

    <!-- Chat Modal -->
    <ChatModal />

    <!-- Contenido principal -->
    <main class="min-h-screen">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
          <p class="text-sm text-gray-500">
            &copy; {new Date().getFullYear()} Estok - Sistema de Inventario Personal
          </p>
          <p class="text-sm text-gray-400">
            Construido con Astro + Tailwind CSS
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
  import { getCachedUser, getEstokActivoId, generarCodigoInvitacion, fetchRoles as fetchRolesFromAuth } from '../services/auth';

  // ===========================================================================
  // SISTEMA DE TOASTS GLOBAL
  // ===========================================================================

  const toastContainer = document.getElementById('toastContainer')!;
  let toastCount = 0;

  const TOAST_ICONS: Record<string, string> = {
    success: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    error: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    info: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    warning: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>`,
  };

  const TOAST_COLORS: Record<string, string> = {
    success: 'bg-green-600 text-white',
    error: 'bg-red-600 text-white',
    info: 'bg-blue-600 text-white',
    warning: 'bg-amber-500 text-white',
  };

  function showToast(message: string, type: string = 'info', duration: number = 4000): string {
    const id = `toast-${++toastCount}`;
    const toast = document.createElement('div');
    toast.id = id;
    toast.className = `pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-lg shadow-lg ${TOAST_COLORS[type] || TOAST_COLORS.info} transform translate-x-full opacity-0 transition-all duration-300 ease-out max-w-sm`;
    toast.innerHTML = `
      <span class="flex-shrink-0">${TOAST_ICONS[type] || TOAST_ICONS.info}</span>
      <span class="flex-1 text-sm font-medium">${message}</span>
      <button onclick="document.getElementById('${id}')?.remove()" class="flex-shrink-0 opacity-70 hover:opacity-100">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    `;
    toastContainer.appendChild(toast);

    requestAnimationFrame(() => {
      toast.classList.remove('translate-x-full', 'opacity-0');
    });

    if (duration > 0) {
      setTimeout(() => {
        toast.classList.add('translate-x-full', 'opacity-0');
        setTimeout(() => toast.remove(), 300);
      }, duration);
    }

    return id;
  }

  // Exponer globalmente
  (window as any).showToast = showToast;
  (window as any).showSuccess = (msg: string) => showToast(msg, 'success');
  (window as any).showError = (msg: string) => showToast(msg, 'error');
  (window as any).showInfo = (msg: string) => showToast(msg, 'info');
  (window as any).showWarning = (msg: string) => showToast(msg, 'warning');

  // ===========================================================================
  // CONTROL DE AUTENTICACIÓN EN LA NAVEGACIÓN
  // ===========================================================================

  const authSection = document.getElementById('authSection')!;
  const loginLink = document.getElementById('loginLink')!;
  const userName = document.getElementById('userName')!;
  const logoutBtn = document.getElementById('logoutBtn')!;

  // Elementos del Estok activo
  const estokSection = document.getElementById('estokSection')!;
  const estokNombre = document.getElementById('estokNombre')!;
  const estokRoleBadge = document.getElementById('estokRoleBadge')!;
  const invitarBtn = document.getElementById('invitarBtn')!;

  // Elementos del dropdown de Estoks
  const estokDropdownBtn = document.getElementById('estokDropdownBtn')!;
  const estokDropdownMenu = document.getElementById('estokDropdownMenu')!;
  const estokDropdownList = document.getElementById('estokDropdownList')!;

  function getRoleBadgeClass(role: string | null): string {
    switch (role) {
      case 'Admin': return 'bg-purple-100 text-purple-700';
      case 'Editor': return 'bg-blue-100 text-blue-700';
      case 'Visualizador': return 'bg-gray-100 text-gray-700';
      default: return 'bg-gray-100 text-gray-500';
    }
  }

  function renderEstokDropdown(estoks: any[], activoId: string | null) {
    estokDropdownList.innerHTML = estoks.map(e => {
      const esActivo = e.id === activoId;
      return `
        <button
          data-estok-id="${e.id}"
          class="estok-dropdown-item flex items-center gap-3 w-full px-3 py-2.5 text-sm hover:bg-blue-50 transition-base text-left ${esActivo ? 'bg-blue-50 font-semibold text-blue-800' : 'text-gray-700'}"
        >
          <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center text-sm flex-shrink-0">
            📋
          </div>
          <div class="flex-1 min-w-0">
            <div class="truncate ${esActivo ? 'font-semibold' : ''}">${e.nombre}</div>
            <span class="inline-block mt-0.5 px-2 py-0.5 rounded-full text-xs font-medium ${getRoleBadgeClass(e.role)}">
              ${e.role || 'Sin rol'}
            </span>
          </div>
          ${esActivo ? '<svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>' : ''}
        </button>
      `;
    }).join('');

    // Event listeners para cambiar de Estok
    document.querySelectorAll('.estok-dropdown-item').forEach(btn => {
      btn.addEventListener('click', async () => {
        const estokId = (btn as HTMLElement).dataset.estokId!;
        if (estokId === getEstokActivoId()) {
          cerrarDropdown();
          return;
        }
        try {
          const { cambiarEstokActivo } = await import('../services/auth');
          await cambiarEstokActivo(estokId);
          cerrarDropdown();
          (window as any).showSuccess?.('✅ Estok cambiado');
          // Recargar la página para refrescar todos los datos
          window.location.reload();
        } catch (err: any) {
          (window as any).showError?.(err?.error || 'Error al cambiar de Estok');
        }
      });
    });
  }

  async function abrirDropdown() {
    // Refrescar datos del usuario desde el backend para tener Estoks actualizados
    try {
      const { fetchCurrentUser } = await import('../services/auth');
      const userFresco = await fetchCurrentUser();
      if (userFresco?.estoks) {
        const estokActivoId = getEstokActivoId();
        renderEstokDropdown(userFresco.estoks, estokActivoId);
      }
    } catch {
      // Fallback: usar datos cacheados
      const user = getCachedUser();
      const estokActivoId = getEstokActivoId();
      if (user?.estoks) {
        renderEstokDropdown(user.estoks, estokActivoId);
      }
    }
    estokDropdownMenu.classList.remove('hidden');
  }

  function cerrarDropdown() {
    estokDropdownMenu.classList.add('hidden');
  }

  function toggleDropdown() {
    if (estokDropdownMenu.classList.contains('hidden')) {
      abrirDropdown();
