          </div>
          <div class="flex-1 min-w-0">
            <div class="truncate ${esActivo ? 'font-semibold' : ''}">${e.nombre}</div>
            <span class="inline-block mt-0.5 px-2 py-0.5 rounded-full text-xs font-medium ${getRoleBadgeClass(e.role)}">
