---
// =============================================================================
// LAYOUT DE AUTENTICACIÓN - Estok Inventory System
// Diseño minimalista para páginas de login/registro
// =============================================================================

// Importar estilos globales (Astro los procesa y los pone en /assets/ con hash)
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = 'Estok - Autenticación' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Inicio de sesión - Estok Inventory System" />
    <meta name="theme-color" content="#1e40af" />
    <title>{title}</title>

    <!-- PWA: Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Estok" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md px-6">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="text-4xl font-bold text-blue-700">Estok</a>
        <p class="text-gray-500 mt-2">Sistema de Inventario Personal</p>
      </div>

      <!-- Banner de actualización -->
      <div id="updateBanner" class="hidden mb-4 bg-green-50 border border-green-200 text-green-800 rounded-xl p-4 shadow-sm">
        <div class="flex items-center gap-3">
          <svg class="w-6 h-6 flex-shrink-0 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          <div>
            <p class="text-sm font-semibold">🆕 Estok ha sido actualizado</p>
            <p class="text-xs text-green-600 mt-0.5">Se ha desplegado una nueva versión de la aplicación.</p>
          </div>
        </div>
      </div>

      <!-- Contenido del formulario -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <slot />
      </div>
    </div>
  </body>
</html>

<script>
  // ===========================================================================
  // DETECCIÓN DE NUEVA VERSIÓN (POST-DEPLOY)
  // Al cargar la página de login, consulta /api/version/ y compara con
  // la versión guardada en localStorage. Si cambió, muestra un banner
  // y limpia el cache del navegador.
  // ===========================================================================

  const VERSION_KEY = 'estok_version_cache';

  async function checkNewVersion() {
    try {
      // Cache buster para evitar cualquier cache del navegador
      const response = await fetch(`/api/version/?_t=${Date.now()}`);
      if (!response.ok) return;
      
      const versionData = await response.json();
      const currentCommit = versionData.commit;

      if (!currentCommit || currentCommit === 'unknown') return;

      // Usar sessionStorage para que cada nueva sesión detecte cambios
      const cachedVersion = sessionStorage.getItem(VERSION_KEY);

      if (cachedVersion && cachedVersion !== currentCommit) {
        // ¡Nuevo deploy detectado!
        console.log('🆕 Nueva versión detectada:', currentCommit, '(anterior:', cachedVersion, ')');

        // Mostrar banner
        const banner = document.getElementById('updateBanner');
        if (banner) {
          banner.classList.remove('hidden');
          // Auto-ocultar después de 8 segundos
          setTimeout(() => {
            banner.classList.add('hidden');
          }, 8000);
        }

        // Limpiar cache del navegador
        if ('caches' in window) {
          try {
            const cacheNames = await caches.keys();
            await Promise.all(cacheNames.map(name => caches.delete(name)));
            console.log('🗑️ Cache limpiado');
          } catch (err) {
            console.warn('⚠️ Error limpiando cache:', err);
          }
        }

        // Desregistrar Service Workers viejos
        if ('serviceWorker' in navigator) {
          try {
            const registrations = await navigator.serviceWorker.getRegistrations();
            await Promise.all(registrations.map(reg => reg.unregister()));
            console.log('🗑️ Service Workers desregistrados');
          } catch (err) {
            console.warn('⚠️ Error desregistrando SW:', err);
          }
        }
      }

      // Guardar versión actual para futuras comparaciones
      sessionStorage.setItem(VERSION_KEY, currentCommit);

    } catch (err) {
      console.warn('⚠️ Error verificando versión:', err);
    }
  }

  // Ejecutar inmediatamente y luego cada 30 segundos
  checkNewVersion();
  setInterval(checkNewVersion, 30000);
</script>
