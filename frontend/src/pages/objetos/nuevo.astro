---
// =============================================================================
// PÁGINA DE CARGA MANUAL DE OBJETO (Mobile-First)
// Formulario de emergencia para carga manual completa con captura de foto
// Incluye: Editor de imagen (rotar, recortar, brillo) + Botón "Autocompletar con IA"
// Build: 2026-07-01 — Forzar rebuild de bundle Astro
// =============================================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryFields from '../../components/CategoryFields.astro';
import AuthGuard from '../../components/AuthGuard.astro';
import ImageEditor from '../../components/ImageEditor.astro';
---

<AuthGuard />

<BaseLayout title="Estok - Nuevo Objeto | Carga Manual">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Encabezado -->
    <div class="mb-8">
      <a
        href="/objetos"
        class="inline-flex items-center text-sm text-gray-500 hover:text-blue-700 transition-base mb-4"
      >
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver a objetos
      </a>
      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-bold text-gray-900">Nuevo Objeto</h1>
        <!-- AI Status Badge -->
        <span id="aiStatusBadge" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
          <span id="aiStatusDot" class="w-2 h-2 rounded-full bg-gray-400"></span>
          <span id="aiStatusText">Verificando IA...</span>
        </span>
      </div>
      <p class="mt-1 text-gray-500">
        Completa los datos del objeto. Los campos marcados con <span class="text-red-500">*</span> son obligatorios.
      </p>
    </div>

    <!-- Formulario -->
    <form id="objetoForm" class="space-y-6">
      <!-- ================================================================ -->
      <!-- SECCIÓN: CAPTURA DE FOTO (Mobile-First con cámara + Editor) -->
      <!-- ================================================================ -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Foto del Objeto
          <span class="text-xs text-gray-400 font-normal">(toca para editar)</span>
        </h2>

        <!-- Preview de la foto -->
        <div class="mb-4">
          <div
            id="photoPreview"
            class="w-full h-48 sm:h-64 bg-gray-100 rounded-lg border-2 border-dashed border-gray-300 flex items-center justify-center overflow-hidden cursor-pointer"
          >
            <div id="photoPlaceholder" class="text-center text-gray-400">
              <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="text-sm">Toca para tomar o seleccionar foto</p>
              <p class="text-xs mt-1">Podrás editarla antes de guardar</p>
            </div>
            <img id="photoImage" class="hidden w-full h-full object-cover" alt="Preview" />
          </div>
        </div>

        <!-- Botones de cámara / galería -->
        <div class="flex flex-col sm:flex-row gap-3">
          <label class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-blue-700 text-white font-medium rounded-lg hover:bg-blue-800 transition-base cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
            </svg>
            Tomar Foto
            <input id="cameraInput" type="file" accept="image/*" capture="environment" class="hidden" />
          </label>
          <label class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-base cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Seleccionar de Galería
            <input id="galleryInput" type="file" accept="image/*" class="hidden" />
          </label>
        </div>

        <!-- Botón para editar foto (visible solo cuando hay foto) -->
        <button type="button" id="editPhotoBtn"
          class="mt-3 hidden w-full sm:w-auto inline-flex items-center justify-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-base">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
          </svg>
          ✏️ Editar Foto
        </button>

        <input type="hidden" name="imagen_base64" id="imagenBase64" />
        <!-- Boton para quitar la foto actual -->
        <button type="button" id="clearPhotoBtn"
          class="mt-3 hidden w-full sm:w-auto inline-flex items-center justify-center gap-2 px-4 py-2 bg-red-50 text-red-600 font-medium rounded-lg hover:bg-red-100 transition-base">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Quitar Foto
        </button>
      </div>

      <!-- ================================================================ -->
      <!-- SECCIÓN: IA - Analizar / Autocompletar -->
      <!-- ================================================================ -->
      <div id="iaSection" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Análisis con Inteligencia Artificial
        </h2>
        <p class="text-sm text-gray-500 mb-4">
          Toma o selecciona una foto, edítala si lo deseas, y presiona "Analizar con IA" para llenar los campos automáticamente.
        </p>

        <!-- Selector de motor IA -->
        <div class="mb-4 p-4 bg-gray-50 border border-gray-200 rounded-lg">
          <label class="block text-sm font-medium text-gray-700 mb-2">Motor de análisis:</label>
          <div class="flex gap-2">
            <button type="button" id="motorLocalBtn" data-motor="local"
              class="flex-1 px-3 py-2.5 text-sm font-medium rounded-lg border-2 transition-all text-left
              border-purple-700 bg-purple-50 text-purple-800">
              <div class="flex items-center gap-2">
                <span class="text-lg">🖥️</span>
                <div>
                  <div class="font-semibold">Local (LM Studio)</div>
                  <div class="text-xs opacity-75 mt-0.5">Privado — tus fotos nunca salen de tu red. Requiere que tu PC esté encendida y conectada.</div>
                </div>
              </div>
            </button>
            <button type="button" id="motorGeminiBtn" data-motor="gemini"
              class="flex-1 px-3 py-2.5 text-sm font-medium rounded-lg border-2 transition-all text-left
              border-gray-200 bg-white text-gray-600 hover:border-gray-300">
              <div class="flex items-center gap-2">
                <span class="text-lg">☁️</span>
                <div>
                  <div class="font-semibold">Gemini (nube)</div>
                  <div class="text-xs opacity-75 mt-0.5">Más rápido y disponible siempre. Tus fotos se procesan en servidores de Google.</div>
                </div>
              </div>
            </button>
          </div>
          <input type="hidden" id="motorSeleccionado" value="local" />
        </div>

        <!-- Indicador de progreso (indeterminado - no simula porcentaje) -->
        <div id="iaProgressContainer" class="hidden mb-4 p-4 bg-purple-50 border border-purple-200 rounded-lg">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 border-4 border-purple-200 border-t-purple-700 rounded-full animate-spin"></div>
            <div>
              <p id="iaProgressText" class="text-sm font-medium text-purple-800">Analizando imagen con IA...</p>
              <p id="iaProgressSubtext" class="text-xs text-purple-600">Procesando en GPU Radeon RX 9060 XT</p>
            </div>
          </div>
          <!-- Barra indeterminada (animación continua, sin porcentaje falso) -->
          <div class="w-full bg-purple-200 rounded-full h-2 overflow-hidden mt-3">
            <div class="bg-purple-700 h-2 rounded-full animate-indeterminate" style="width: 40%"></div>
          </div>
        </div>

        <!-- Botón: Analizar con IA (antes de guardar) -->
        <button type="button" id="analizarIaBtn" disabled
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 bg-purple-700 text-white font-medium rounded-lg hover:bg-purple-800 transition-base shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
          <span id="iaBtnText">
            <svg class="w-5 h-5 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Analizar con IA
          </span>
          <span id="iaBtnSpinner" class="hidden">
            <svg class="animate-spin h-5 w-5 inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Analizando...
          </span>
        </button>

        <!-- Sección de segunda foto para libros (oculta inicialmente) -->
        <div id="segundaFotoSection" class="hidden mt-4 p-4 bg-amber-50 border border-amber-200 rounded-lg">
          <div class="flex items-start gap-3">
            <div class="text-2xl">📖</div>
            <div>
              <h3 class="font-semibold text-amber-800 text-sm">¡Libro detectado!</h3>
              <p id="segundaFotoMotivo" class="text-sm text-amber-700 mt-1"></p>
              <div class="mt-3 flex flex-col sm:flex-row gap-2">
                <label class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2 bg-amber-600 text-white text-sm font-medium rounded-lg hover:bg-amber-700 transition-base cursor-pointer">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                  </svg>
                  Tomar foto de la parte trasera
                  <input id="segundaFotoInput" type="file" accept="image/*" capture="environment" class="hidden" />
                </label>
                <button type="button" id="saltarSegundaFotoBtn"
                  class="px-4 py-2 text-sm text-amber-700 font-medium hover:text-amber-900 transition-base">
                  Saltar, ya tengo el ISBN
                </button>
              </div>
            </div>
          </div>
        </div>

        <div id="iaStatus" class="mt-3 text-sm hidden"></div>
      </div>

      <!-- ================================================================ -->
      <!-- SECCIÓN: DATOS BÁSICOS -->
      <!-- ================================================================ -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Datos Básicos</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">Nombre del objeto <span class="text-red-500">*</span></label>
            <input id="nombre" name="nombre" type="text" required placeholder="Ej: iPhone 14 Pro, El Principito, Sillón de cuero"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base" />
          </div>
          <div class="sm:col-span-2">
            <label for="descripcion" class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
            <textarea id="descripcion" name="descripcion" rows={3} placeholder="Describe el objeto, su estado, historia o cualquier detalle relevante..."
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base"></textarea>
          </div>
          <div>
            <label for="tipo" class="block text-sm font-medium text-gray-700 mb-1">Categoría <span class="text-red-500">*</span></label>
            <select id="tipo" name="tipo" required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base bg-white">
              <option value="">Seleccionar categoría...</option>
              <option value="libro">📚 Libro / Revista</option>
              <option value="tecnologia">💻 Tecnología</option>
              <option value="mueble">🖼️ Mueble / Arte</option>
              <option value="ropa">👕 Ropa / Accesorio</option>
              <option value="objeto">📦 Otro / Genérico</option>
            </select>
          </div>
          <div>
            <label for="estado_conservacion" class="block text-sm font-medium text-gray-700 mb-1">Estado de conservación</label>
            <select id="estado_conservacion" name="estado_conservacion"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base bg-white">
              <option value="excelente">Excelente</option>
              <option value="bueno" selected>Bueno</option>
              <option value="regular">Regular</option>
              <option value="malo">Malo</option>
              <option value="muy_malo">Muy malo</option>
            </select>
          </div>
          <div>
            <label for="color" class="block text-sm font-medium text-gray-700 mb-1">Color</label>
            <input id="color" name="color" type="text" placeholder="Ej: Rojo, Negro, Plateado"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base" />
          </div>
          <div>
            <label for="valor_estimado" class="block text-sm font-medium text-gray-700 mb-1">Valor estimado (USD)</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
              <input id="valor_estimado" name="valor_estimado" type="number" step="0.01" min="0" placeholder="0.00"
                class="w-full pl-8 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base" />
            </div>
            <button type="button" id="estimarPrecioBtn"
              class="mt-2 inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-base disabled:opacity-50 disabled:cursor-not-allowed">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <span id="estimarPrecioText">Buscar precio de referencia</span>
              <span id="estimarPrecioSpinner" class="hidden">
                <svg class="animate-spin h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </span>
            </button>
            <div id="precioReferencia" class="mt-2 text-xs hidden"></div>
          </div>
        </div>
      </div>

      <!-- ================================================================ -->
      <!-- SECCIÓN: CAMPOS ESPECÍFICOS POR CATEGORÍA -->
      <!-- ================================================================ -->
      <div id="categoryFieldsContainer">
        <CategoryFields tipo="objeto" />
      </div>

      <!-- ================================================================ -->
      <!-- SECCIÓN: UBICACIÓN -->
      <!-- ================================================================ -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Ubicación</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="ubicacion" class="block text-sm font-medium text-gray-700 mb-1">Ubicación</label>
            <select id="ubicacion" name="ubicacion"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base bg-white">
              <option value="">Sin ubicación</option>
            </select>
          </div>
          <div>
            <label for="contenedor" class="block text-sm font-medium text-gray-700 mb-1">Contenedor</label>
            <select id="contenedor" name="contenedor"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base bg-white">
              <option value="">Sin contenedor</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ================================================================ -->
      <!-- SECCIÓN: LEGADO Y TRAZABILIDAD -->
      <!-- ================================================================ -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Legado y Trazabilidad
        </h2>
        <p class="text-sm text-gray-500 mb-4">
          Estos campos son fundamentales para el sistema de planificación sucesoria familiar.
          Definen quién fue el dueño original del objeto y quién es el beneficiario designado.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="dueno_original" class="block text-sm font-medium text-gray-700 mb-1">Dueño original</label>
            <select id="dueno_original" name="dueno_original"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base bg-white">
              <option value="">Seleccionar dueño original...</option>
            </select>
          </div>
          <div>
            <label for="beneficiario" class="block text-sm font-medium text-gray-700 mb-1">Beneficiario</label>
            <select id="beneficiario" name="beneficiario"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base bg-white">
              <option value="">Seleccionar beneficiario...</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ================================================================ -->
      <!-- BOTÓN DE ENVÍO -->
      <!-- ================================================================ -->
      <div class="flex flex-col sm:flex-row gap-4 pt-4">
        <button type="submit" id="submitBtn"
          class="flex-1 px-6 py-3 bg-blue-700 text-white font-medium rounded-lg hover:bg-blue-800 transition-base shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
          <span id="submitText">Guardar Objeto</span>
          <span id="submitSpinner" class="hidden">
            <svg class="animate-spin h-5 w-5 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </span>
        </button>
        <a href="/objetos"
          class="flex-1 px-6 py-3 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-base text-center">
          Cancelar
        </a>
      </div>
    </form>
  </div>

  <!-- Image Editor Component (Modal) -->
  <ImageEditor imageSrc="" />
</BaseLayout>

<script>
  // ===========================================================================
  // IMPORTS
  // ===========================================================================
  import {getAuthHeaders, getToken, getEstokActivoId, API_BASE_URL} from '../../services/auth';
  import {comprimirImagenBase64} from '../../services/image';

  // ===========================================================================
  // CONSTANTES
  // ===========================================================================
  

  // ===========================================================================
  // SELECTOR DE MOTOR IA (Local / Gemini)
  // ===========================================================================
  const motorLocalBtn = document.getElementById('motorLocalBtn');
  const motorGeminiBtn = document.getElementById('motorGeminiBtn');
  const motorSeleccionado = document.getElementById('motorSeleccionado');

  let motorActual = 'local';

  // ===========================================================================
  // AI HEARTBEAT - Verificar disponibilidad del motor IA seleccionado
  // ===========================================================================
  const aiStatusBadge = document.getElementById('aiStatusBadge');
  const aiStatusDot = document.getElementById('aiStatusDot');
  const aiStatusText = document.getElementById('aiStatusText');
  const iaSection = document.getElementById('iaSection');
  const analizarIaBtn = document.getElementById('analizarIaBtn');
  const iaStatus = document.getElementById('iaStatus');

  let iaAvailable = false;

  async function checkAIAvailability(motor?: string) {
    const motorAUsar = motor || motorActual;
    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 5000);
      const response = await fetch(`${API_BASE_URL}/objetos/test_ia_stress/?motor=${motorAUsar}`, {
        method: 'GET',
        headers: getAuthHeaders(),
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      console.log(`[IA] Heartbeat result for motor="${motorAUsar}":`, response.ok);
      return response.ok;
    } catch (err) {
      console.warn(`[IA] Heartbeat error for motor="${motorAUsar}":`, err);
      return false;
    }
  }

  async function updateAIStatus() {
    const connected = await checkAIAvailability();
    iaAvailable = connected;
    console.log('[IA] updateAIStatus: motorActual =', motorActual, '| iaAvailable =', iaAvailable, '| imagenBase64.value =', imagenBase64 ? '(existe)' : 'null', imagenBase64?.value ? '(tiene foto)' : '(sin foto)');
    if (connected) {
      aiStatusBadge.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700';
      aiStatusDot.className = 'w-2 h-2 rounded-full bg-green-500';
      aiStatusText.textContent = motorActual === 'gemini' ? '☁️ Gemini Conectado' : '🖥️ IA Local Conectada';
      iaSection.classList.remove('hidden');
      iaStatus.classList.add('hidden');
      if (imagenBase64 && imagenBase64.value) {
        analizarIaBtn.disabled = false;
      }
    } else {
      aiStatusBadge.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500';
      aiStatusDot.className = 'w-2 h-2 rounded-full bg-gray-400';
      if (motorActual === 'gemini') {
        aiStatusText.textContent = '☁️ Gemini no disponible';
        iaStatus.className = 'mt-3 text-sm text-amber-600';
        iaStatus.textContent = '💡 Gemini no está disponible. Verificá que la API key esté configurada en el servidor.';
      } else {
        aiStatusText.textContent = '🖥️ IA Local no disponible';
        iaStatus.className = 'mt-3 text-sm text-amber-600';
        iaStatus.textContent = '💡 La IA local (LM Studio) no está disponible. Verificá que LM Studio esté corriendo.';
      }
      iaSection.classList.remove('hidden');
      analizarIaBtn.disabled = true;
      iaStatus.classList.remove('hidden');
    }
  }

  // Re-evaluar disponibilidad cuando el usuario cambia de motor
  function seleccionarMotor(motor: string) {
    motorActual = motor;
    motorSeleccionado.value = motor;
    if (motor === 'local') {
      motorLocalBtn.className = 'flex-1 px-3 py-2.5 text-sm font-medium rounded-lg border-2 transition-all text-left border-purple-700 bg-purple-50 text-purple-800';
      motorGeminiBtn.className = 'flex-1 px-3 py-2.5 text-sm font-medium rounded-lg border-2 transition-all text-left border-gray-200 bg-white text-gray-600 hover:border-gray-300';
    } else {
      motorGeminiBtn.className = 'flex-1 px-3 py-2.5 text-sm font-medium rounded-lg border-2 transition-all text-left border-blue-500 bg-blue-50 text-blue-800';
      motorLocalBtn.className = 'flex-1 px-3 py-2.5 text-sm font-medium rounded-lg border-2 transition-all text-left border-gray-200 bg-white text-gray-600 hover:border-gray-300';
    }
    // Re-evaluar disponibilidad para el motor recién seleccionado
    updateAIStatus();
  }

  motorLocalBtn?.addEventListener('click', () => seleccionarMotor('local'));
  motorGeminiBtn?.addEventListener('click', () => seleccionarMotor('gemini'));

  updateAIStatus();
  // Polling: verificar cada 30s si hay conexión, cada 120s si no
  setInterval(async () => {
    if (!iaAvailable) {
      const connected = await checkAIAvailability();
      if (connected) {
        iaAvailable = true;
        updateAIStatus();
      }
    } else {
      updateAIStatus();
    }
  }, iaAvailable ? 30000 : 120000);

  // ===========================================================================
  // MANEJO DE CAPTURA DE FOTO + Editor de imagen
  // ===========================================================================
  const cameraInput = document.getElementById('cameraInput');
  const galleryInput = document.getElementById('galleryInput');
  const photoPreview = document.getElementById('photoPreview');
  const photoPlaceholder = document.getElementById('photoPlaceholder');
  const photoImage = document.getElementById('photoImage');
  const imagenBase64 = document.getElementById('imagenBase64');
  const editPhotoBtn = document.getElementById('editPhotoBtn');
  const iaBtnText = document.getElementById('iaBtnText');
  const iaBtnSpinner = document.getElementById('iaBtnSpinner');

  let savedObjectId = null;

  // ===========================================================================
  // RESTAURAR FOTO DESDE SESSIONSTORAGE (para sobrevivir a refrescos)
  // ===========================================================================
  (function restaurarFoto() {
    // Restaurar foto solo si viene de un F5 (sessionStorage aun existe)
    const fotoGuardada = sessionStorage.getItem('nuevo_objeto_foto');
    if (fotoGuardada) {
      photoImage.src = fotoGuardada;
      photoImage.classList.remove('hidden');
      photoPlaceholder.classList.add('hidden');
      imagenBase64.value = fotoGuardada;
      editPhotoBtn.classList.remove('hidden');
      clearPhotoBtn.classList.remove('hidden');
      if (iaAvailable) {
        analizarIaBtn.disabled = false;
      }
      // Limpiar sessionStorage inmediatamente para que NO sobreviva a navegacion
      // Solo F5 la mantiene porque el script se ejecuta antes de que se borre el storage
      try { sessionStorage.removeItem('nuevo_objeto_foto'); } catch (e) {}
    }
  })();

  // ===========================================================================
  // MANEJAR BFCACHE - Cuando el navegador restaura la pagina desde cache
  // (por ejemplo al volver con el boton Atras), el DOM incluye la foto
  // aunque sessionStorage ya se haya limpiado.
  // ===========================================================================
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      // Pagina restaurada de BFCache - limpiar foto
      photoImage.src = '';
      photoImage.classList.add('hidden');
      photoPlaceholder.classList.remove('hidden');
      imagenBase64.value = '';
      editPhotoBtn.classList.add('hidden');
      const clearBtn = document.getElementById('clearPhotoBtn');
      if (clearBtn) clearBtn.classList.add('hidden');
      analizarIaBtn.disabled = true;
      iaStatus.classList.add('hidden');
      try { sessionStorage.removeItem('nuevo_objeto_foto'); } catch (e) {}
    }
  });

  // ===========================================================================
  // COMPRIMIR IMAGEN EN FRONTEND antes de enviar al backend
  // (función centralizada en services/image.ts)
  // ===========================================================================
  function handleFileSelected(file) {
    if (!file) return;
    const reader = new FileReader();
    reader.onload = async (e) => {
      const result = e.target.result;
      // Comprimir antes de guardar
      let compressed: string;
      try {
        compressed = await comprimirImagenBase64(result);
      } catch (err) {
        console.warn('Error al comprimir imagen, usando original:', err);
        compressed = result;
      }
      photoImage.src = compressed;
      photoImage.classList.remove('hidden');
      photoPlaceholder.classList.add('hidden');
      imagenBase64.value = compressed;
      editPhotoBtn.classList.remove('hidden');
      clearPhotoBtn.classList.remove('hidden');
      analizarIaBtn.disabled = false;
      iaStatus.classList.add('hidden');
      // Persistir foto en sessionStorage para sobrevivir a refrescos
      try {
        sessionStorage.setItem('nuevo_objeto_foto', compressed);
      } catch (e) {
        // Puede fallar si la imagen es muy grande (>5MB aprox)
        console.warn('No se pudo guardar la foto en sessionStorage (posiblemente muy grande):', e);
      }
      setTimeout(() => openEditor(), 300);
    };
    reader.readAsDataURL(file);
  }

  cameraInput.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    if (file) handleFileSelected(file);
    e.target.value = '';
  });

  galleryInput.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    if (file) handleFileSelected(file);
    e.target.value = '';
  });

  photoPreview.addEventListener('click', () => {
    cameraInput.click();
  });

  // ===========================================================================
  // EDITOR DE IMAGEN
  // ===========================================================================
  async function openEditor() {
    if (!imagenBase64.value) return;
    // Esperar a que ImageEditor esté disponible (puede cargar después que este script)
    let editorFn = (window as any).openImageEditor;
    if (!editorFn) {
      // Intentar de nuevo después de un breve delay
      await new Promise(r => setTimeout(r, 500));
      editorFn = (window as any).openImageEditor;
    }
    if (!editorFn) {
      console.warn('ImageEditor no disponible');
      window.showToast?.('⚠️ Editor de imagen no disponible. Intenta de nuevo.', 'warning');
      return;
    }
    const editedImage = await editorFn(imagenBase64.value);
    if (editedImage) {
      imagenBase64.value = editedImage;
      photoImage.src = editedImage;
      window.showToast?.('✅ Imagen editada correctamente', 'success');
    }
  }

  editPhotoBtn.addEventListener('click', openEditor);

  // ===========================================================================
  // LIMPIAR FOTO - Boton para quitar la foto actual
  // ===========================================================================
  const clearPhotoBtn2 = document.getElementById('clearPhotoBtn');
  clearPhotoBtn2?.addEventListener('click', () => {
    photoImage.src = '';
    photoImage.classList.add('hidden');
    photoPlaceholder.classList.remove('hidden');
    imagenBase64.value = '';
    editPhotoBtn.classList.add('hidden');
    clearPhotoBtn2.classList.add('hidden');
    analizarIaBtn.disabled = true;
    iaStatus.classList.add('hidden');
    try { sessionStorage.removeItem('nuevo_objeto_foto'); } catch (e) {}
    window.showToast?.('🗑️ Foto eliminada', 'info');
  });

  // ===========================================================================
  // ESTIMAR PRECIO DE REFERENCIA (scraping backend + Gemini fallback)
  // ===========================================================================
  const estimarPrecioBtn = document.getElementById('estimarPrecioBtn');
  const estimarPrecioText = document.getElementById('estimarPrecioText');
  const estimarPrecioSpinner = document.getElementById('estimarPrecioSpinner');
  const precioReferencia = document.getElementById('precioReferencia');
  const nombreInput = document.getElementById('nombre');

  function getEstadoLabel(estado: string): string {
    const labels: Record<string, string> = {
      excelente: 'Excelente',
      bueno: 'Bueno',
      regular: 'Regular',
      malo: 'Malo',
      muy_malo: 'Muy malo',
    };
    return labels[estado] || estado;
  }

  function getDescuentoLabel(porcentaje: number): string {
    const descuento = 100 - porcentaje;
    return descuento > 0 ? `-${descuento}%` : '0%';
  }

  estimarPrecioBtn.addEventListener('click', async () => {
    const nombre = nombreInput?.value?.trim();
    if (!nombre) {
      window.showToast?.('Primero escribe el nombre del objeto.', 'error');
      nombreInput?.focus();
      return;
    }
    estimarPrecioBtn.disabled = true;
    estimarPrecioText.classList.add('hidden');
    estimarPrecioSpinner.classList.remove('hidden');
    precioReferencia.classList.add('hidden');
    try {
      const estadoActual = (document.getElementById('estado_conservacion') as HTMLSelectElement)?.value || 'bueno';

      // Llamar al nuevo endpoint de precio referencia (scraping + Gemini fallback)
      const response = await fetch(
        `${API_BASE_URL}/objetos/buscar_precio_referencia/?q=${encodeURIComponent(nombre)}&estado=${encodeURIComponent(estadoActual)}`,
        { headers: getAuthHeaders() }
      );

      if (!response.ok) {
        throw new Error(`Error del servidor (${response.status})`);
      }

      const data = await response.json();

      if (data.encontrado) {
        // Autocompletar valor estimado con el precio ajustado
        const valorEstimado = document.getElementById('valor_estimado') as HTMLInputElement;
        if (valorEstimado) {
          valorEstimado.value = data.precio_ajustado.toFixed(2);
          valorEstimado.dispatchEvent(new Event('input', { bubbles: true }));
        }

        // Mostrar tarjeta con el resultado
        const esML = data.fuente === 'mercadolibre_scraping';
        precioReferencia.className = 'mt-2';
        precioReferencia.innerHTML = `
          <div class="${esML ? 'cursor-pointer border border-blue-200 bg-blue-50 hover:bg-blue-100' : 'border border-purple-200 bg-purple-50'} rounded-lg p-3 transition-base" ${esML ? `data-link="${data.link}"` : ''}>
            <div class="flex items-start gap-2">
              <span class="text-lg">${esML ? '📦' : '🤖'}</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate">${data.titulo}</p>
                <div class="mt-1 space-y-0.5">
                  <p class="text-xs text-gray-500">Precio original: <span class="font-semibold text-gray-700">$${data.precio_original.toFixed(2)}</span></p>
                  <p class="text-xs text-gray-500">Ajuste por estado (${getEstadoLabel(data.estado_aplicado)} ${getDescuentoLabel(data.porcentaje_aplicado)}): <span class="font-semibold text-blue-700">$${data.precio_ajustado.toFixed(2)}</span></p>
                  ${esML
                    ? '<p class="text-xs text-blue-600 mt-1">🔗 Ver en MercadoLibre →</p>'
                    : '<p class="text-xs text-purple-600 mt-1">🤖 Estimación de IA (Gemini)</p>'
                  }
                </div>
              </div>
            </div>
          </div>
        `;
        precioReferencia.classList.remove('hidden');

        // Click en la tarjeta abre el link de ML
        if (esML) {
          const tarjeta = precioReferencia.querySelector('[data-link]') as HTMLElement;
          if (tarjeta) {
            tarjeta.addEventListener('click', () => {
              const link = tarjeta.dataset.link;
              if (link) {
                window.open(link, '_blank');
              }
            });
          }
        }

        window.showToast?.(`💰 Precio de referencia: $${data.precio_ajustado.toFixed(2)}`, 'success');
      } else {
        // No se encontró precio de referencia
        precioReferencia.className = 'mt-2 text-xs text-amber-600';
        precioReferencia.textContent = '💡 No se encontró precio de referencia para este objeto.';
        precioReferencia.classList.remove('hidden');
        window.showToast?.('No se encontró precio de referencia.', 'info');
      }
    } catch (err) {
      console.error('Error al buscar precio de referencia:', err);
      precioReferencia.className = 'mt-2 text-xs text-red-600';
      precioReferencia.textContent = '❌ Error de conexión al buscar precios.';
      precioReferencia.classList.remove('hidden');
    } finally {
      estimarPrecioBtn.disabled = false;
      estimarPrecioText.classList.remove('hidden');
      estimarPrecioSpinner.classList.add('hidden');
    }
  });

  // ===========================================================================
  // CARGAR DATOS INICIALES (Ubicaciones, Contenedores, Usuarios)
  // ===========================================================================
  async function cargarUbicaciones() {
    try {
      const response = await fetch(`${API_BASE_URL}/ubicaciones/`, {
        headers: getAuthHeaders(),
      });
      if (response.ok) {
        const data = await response.json();
        const ubicaciones = data.results || data;
        const select = document.getElementById('ubicacion');
        ubicaciones.forEach((u) => {
          const opt = document.createElement('option');
          opt.value = u.id;
          opt.textContent = u.nombre;
          select.appendChild(opt);
        });
      }
    } catch (err) {
      console.error('Error cargando ubicaciones:', err);
    }
  }

  async function cargarContenedores() {
    try {
      const response = await fetch(`${API_BASE_URL}/contenedores/`, {
        headers: getAuthHeaders(),
      });
      if (response.ok) {
        const data = await response.json();
        const contenedores = data.results || data;
        const select = document.getElementById('contenedor');
        contenedores.forEach((c) => {
          const opt = document.createElement('option');
          opt.value = c.id;
          opt.textContent = `${c.nombre} (${c.ubicacion_nombre || ''})`;
          select.appendChild(opt);
        });
      }
    } catch (err) {
      console.error('Error cargando contenedores:', err);
    }
  }

  async function cargarUsuarios() {
    try {
      const response = await fetch(`${API_BASE_URL}/usuarios/`, {
        headers: getAuthHeaders(),
      });
      if (response.ok) {
        const data = await response.json();
        const usuarios = data.results || data;
        const duenoSelect = document.getElementById('dueno_original');
        const benSelect = document.getElementById('beneficiario');
        usuarios.forEach((u) => {
          const opt1 = document.createElement('option');
          opt1.value = u.id;
          opt1.textContent = u.full_name || u.username || u.email;
          duenoSelect.appendChild(opt1);
          const opt2 = document.createElement('option');
          opt2.value = u.id;
          opt2.textContent = u.full_name || u.username || u.email;
          benSelect.appendChild(opt2);
        });
      }
    } catch (err) {
      console.error('Error cargando usuarios:', err);
    }
  }

  cargarUbicaciones();
  cargarContenedores();
  cargarUsuarios();

  // ===========================================================================
  // CAMBIAR CATEGORÍA - Actualizar campos específicos
  // ===========================================================================
  const tipoSelect = document.getElementById('tipo');
  const categoryContainer = document.getElementById('categoryFieldsContainer');

  tipoSelect.addEventListener('change', () => {
    const tipo = tipoSelect.value || 'objeto';
    // Actualizar CategoryFields localmente (sin llamada API)
    if ((window as any).updateCategoryFields) {
      (window as any).updateCategoryFields(tipo);
    }
  });

  // ===========================================================================
  // ANALIZAR CON IA - Enviar imagen Base64 al backend para análisis ANTES de guardar
  // ===========================================================================
  const iaProgressContainer = document.getElementById('iaProgressContainer');
  const iaProgressText = document.getElementById('iaProgressText');
  const iaProgressSubtext = document.getElementById('iaProgressSubtext');
  const iaProgressBar = document.getElementById('iaProgressBar');
  const iaProgressPercent = document.getElementById('iaProgressPercent');

  analizarIaBtn.addEventListener('click', async () => {
    // =====================================================================
    // FIX: Todo el handler envuelto en try/catch desde la primera línea
    // para evitar errores silenciosos antes del fetch.
    // =====================================================================
    try {
      console.log('[IA] Click en Analizar IA detectado');

      // Guard clauses: verificar que todos los elementos del DOM existan
      if (!analizarIaBtn) { console.error('[IA] analizarIaBtn no encontrado en el DOM'); return; }
      if (!imagenBase64) { console.error('[IA] elemento imagenBase64 no encontrado en el DOM'); return; }
      if (!iaBtnText) { console.error('[IA] iaBtnText no encontrado en el DOM'); return; }
      if (!iaBtnSpinner) { console.error('[IA] iaBtnSpinner no encontrado en el DOM'); return; }
      if (!iaProgressContainer) { console.error('[IA] iaProgressContainer no encontrado en el DOM'); return; }
      if (!iaProgressText) { console.error('[IA] iaProgressText no encontrado en el DOM'); return; }
      if (!iaProgressSubtext) { console.error('[IA] iaProgressSubtext no encontrado en el DOM'); return; }
      if (!iaStatus) { console.error('[IA] iaStatus no encontrado en el DOM'); return; }

      // Validar que haya foto cargada
      const base64Image = imagenBase64.value;
      if (!base64Image) {
        window.showToast?.('❌ Primero toma o selecciona una foto.', 'error');
        return;
      }

      // Validar que la IA esté disponible (por si el botón se habilitó incorrectamente)
      if (!iaAvailable) {
        const msg = motorActual === 'gemini'
          ? '❌ Gemini no está disponible. Verificá que la API key esté configurada en el servidor.'
          : '❌ La IA local (LM Studio) no está disponible. Verificá que LM Studio esté corriendo.';
        window.showToast?.(msg, 'error');
        return;
      }

      // Mostrar progreso (indicador indeterminado - sin porcentaje falso)
      analizarIaBtn.disabled = true;
      iaBtnText.classList.add('hidden');
      iaBtnSpinner.classList.remove('hidden');
      iaProgressContainer.classList.remove('hidden');
      iaProgressText.textContent = '🤖 Analizando imagen con IA...';
      iaProgressSubtext.textContent = motorActual === 'gemini' ? '☁️ Procesando en Google Gemini (nube)' : '🖥️ Procesando en LM Studio (local)';
      iaStatus.classList.add('hidden');

      // AbortController con timeout de 210s (mayor que Gunicorn 200s y Nginx 200s)
      const controller = new AbortController();
      const timeoutId = setTimeout(() => {
        console.warn('[IA] Timeout de 210s alcanzado, abortando fetch');
        controller.abort();
      }, 210000);

      // Mensajes de expectativa para el usuario mientras espera
      const expectativaId = setTimeout(() => {
        iaProgressText.textContent = '⏳ La IA está procesando... esto puede tomar hasta 3 minutos.';
        iaProgressSubtext.textContent = 'No cierres la página, el análisis sigue en curso.';
      }, 30000);
      const expectativaId2 = setTimeout(() => {
        iaProgressText.textContent = '⏳ Sigo procesando... gracias por esperar.';
        iaProgressSubtext.textContent = 'Si no responde en 2 minutos más, se cancelará automáticamente.';
      }, 90000);

      console.log('[IA] Enviando fetch a analizar_imagen con timeout de 210s');
      const response = await fetch(`${API_BASE_URL}/objetos/analizar_imagen/`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...getAuthHeaders(),
        },
        body: JSON.stringify({
          imagen_base64: base64Image,
          solo_analisis: true,
          motor: motorActual,
        }),
        signal: controller.signal,
      });

      console.log('[IA] Fetch completado, status:', response.status);
      clearTimeout(timeoutId);
      iaProgressText.textContent = '✅ Análisis completado';

      if (!response.ok) {
        const errData = await response.json();
        throw new Error(errData.error || 'Error al analizar con IA');
      }

      const result = await response.json();
      const datos = result.datos_ia || result;

      // Autocompletar campos en el formulario
      if (datos.nombre) {
        document.getElementById('nombre').value = datos.nombre;
      }
      if (datos.descripcion) {
        document.getElementById('descripcion').value = datos.descripcion;
      }
      if (datos.estado_conservacion) {
        const estadoSelect = document.getElementById('estado_conservacion');
        if ([...estadoSelect.options].some(o => o.value === datos.estado_conservacion)) {
          estadoSelect.value = datos.estado_conservacion;
        }
      }
      if (datos.color) {
        document.getElementById('color').value = datos.color;
      }
      if (datos.categoria) {
        const tipoMap = { libro: 'libro', tecnologia: 'tecnologia', mueble: 'mueble', ropa: 'ropa' };
        const tipoVal = tipoMap[datos.categoria];
        if (tipoVal && tipoSelect) {
          tipoSelect.value = tipoVal;
          tipoSelect.dispatchEvent(new Event('change'));
        }
      }
      if (datos.precio_estimado_mercado) {
        document.getElementById('valor_estimado').value = datos.precio_estimado_mercado;
      }

      // Campos específicos
      if (datos.autor) {
        const autorInput = document.querySelector('[name="autor"]');
        if (autorInput) autorInput.value = datos.autor;
      }
      if (datos.marca) {
        const marcaInput = document.querySelector('[name="marca"]');
        if (marcaInput) marcaInput.value = datos.marca;
      }
      if (datos.nombre_serie) {
        const serieInput = document.querySelector('[name="nombre_serie"]');
        if (serieInput) serieInput.value = datos.nombre_serie;
      }
      if (datos.titulo_tomo) {
        const tomoInput = document.querySelector('[name="titulo_tomo"]');
        if (tomoInput) tomoInput.value = datos.titulo_tomo;
      }
      if (datos.numero_tomo) {
        const numInput = document.querySelector('[name="numero_tomo"]');
        if (numInput) numInput.value = datos.numero_tomo;
      }
      if (datos.editorial) {
        const editInput = document.querySelector('[name="editorial"]');
        if (editInput) editInput.value = datos.editorial;
      }
      if (datos.idioma) {
        const idiomaInput = document.querySelector('[name="idioma"]');
        if (idiomaInput) idiomaInput.value = datos.idioma;
      }
      if (datos.isbn_issn) {
        const isbnInput = document.querySelector('[name="isbn_issn"]');
        if (isbnInput) isbnInput.value = datos.isbn_issn;
      }
      if (datos.edicion) {
        const edicionInput = document.querySelector('[name="edicion"]');
        if (edicionInput) edicionInput.value = datos.edicion;
      }

            // Mostrar campos pendientes - MENSAJE ÚNICO, no contradictorio
            const camposPendientes = result.campos_pendientes || datos.campos_pendientes || [];
            const camposCompletados = Object.entries(datos).filter(([k, v]) => {
              if (k === 'raw_response' || k === 'confianza_general' || k === 'campos_pendientes') return false;
              return v !== null && v !== undefined && v !== '';
            }).map(([k]) => k);

            if (camposPendientes.length === 0) {
              // Éxito total: todos los campos se autocompletaron
              iaStatus.className = 'mt-3 text-sm text-green-600';
              iaStatus.textContent = '✅ Todos los campos fueron completados por la IA.';
              window.showToast?.('🤖 Todos los campos autocompletados por IA correctamente.', 'success');
            } else if (camposCompletados.length > 0) {
              // Éxito parcial: algunos campos se autocompletaron, otros no
              iaStatus.className = 'mt-3 text-sm text-amber-600';
              iaStatus.innerHTML = `⚠️ Se autocompletaron: <strong>${camposCompletados.join(', ')}</strong>. Quedaron pendientes: <strong>${camposPendientes.join(', ')}</strong>. Revisalos manualmente.`;
              window.showToast?.(`🤖 Se autocompletaron ${camposCompletados.length} campo(s). Revisá los pendientes.`, 'info');
            } else {
              // No se autocompletó nada
              iaStatus.className = 'mt-3 text-sm text-red-600';
              iaStatus.textContent = '❌ La IA no pudo determinar ningún campo. Revisá la foto e intentá de nuevo.';
              window.showToast?.('❌ La IA no pudo autocompletar ningún campo.', 'error');
            }
            iaStatus.classList.remove('hidden');

            // Verificar si la IA detectó que es un libro y necesita segunda foto
            if (result.necesita_segunda_foto) {
              const segundaFotoSection = document.getElementById('segundaFotoSection');
              const segundaFotoMotivo = document.getElementById('segundaFotoMotivo');
              if (segundaFotoSection && segundaFotoMotivo) {
                segundaFotoMotivo.textContent = result.motivo_segunda_foto || 'Toma una foto de la parte trasera para capturar el código ISBN.';
                segundaFotoSection.classList.remove('hidden');
                window.showToast?.('📖 Libro detectado. Toma una foto de la parte trasera para obtener el ISBN.', 'info');
              }
            }

            // Si es la segunda foto y se detectó ISBN, mostrarlo
            if (result.isbn_detectado) {
              const isbnInput = document.querySelector('[name="isbn_issn"]');
              if (isbnInput) {
                isbnInput.value = result.isbn_detectado;
                window.showToast?.(`✅ ISBN detectado: ${result.isbn_detectado}`, 'success');
              }
              // Ocultar la sección de segunda foto
              const segundaFotoSection = document.getElementById('segundaFotoSection');
              if (segundaFotoSection) {
                segundaFotoSection.classList.add('hidden');
              }
            }

    } catch (err) {
      console.error('[IA] Error en handler de Analizar IA:', err);
      let mensaje = 'Error al analizar con IA';
      if (err.name === 'AbortError') {
        mensaje = 'El análisis está tardando más de lo esperado. La IA puede estar ocupada o no disponible. Intentá de nuevo.';
      } else if (err instanceof Error) {
        mensaje = err.message;
      }
      if (iaProgressText) iaProgressText.textContent = '❌ Error en el análisis';
      if (iaProgressSubtext) iaProgressSubtext.textContent = mensaje;
      window.showToast?.(`❌ ${mensaje}`, 'error');
    } finally {
      setTimeout(() => {
        if (iaProgressContainer) iaProgressContainer.classList.add('hidden');
        if (analizarIaBtn) analizarIaBtn.disabled = false;
        if (iaBtnText) iaBtnText.classList.remove('hidden');
        if (iaBtnSpinner) iaBtnSpinner.classList.add('hidden');
      }, 3000);
    }
  });

  // ===========================================================================
  // SEGUNDA FOTO PARA LIBROS - Manejar captura de parte trasera
  // ===========================================================================
  const segundaFotoInput = document.getElementById('segundaFotoInput');
  const saltarSegundaFotoBtn = document.getElementById('saltarSegundaFotoBtn');
  const segundaFotoSection = document.getElementById('segundaFotoSection');

  segundaFotoInput?.addEventListener('change', async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    // Mostrar progreso
    analizarIaBtn.disabled = true;
    iaBtnText.classList.add('hidden');
    iaBtnSpinner.classList.remove('hidden');
    iaProgressContainer.classList.remove('hidden');
    iaProgressText.textContent = '📖 Analizando parte trasera del libro...';
    iaProgressSubtext.textContent = 'Buscando código ISBN...';
    iaProgressBar.style.width = '10%';
    iaProgressPercent.textContent = '10%';
    iaStatus.classList.add('hidden');

    try {
      const reader = new FileReader();
      const rawBase64 = await new Promise((resolve) => {
        reader.onload = (ev) => resolve(ev.target.result);
        reader.readAsDataURL(file);
      });
      // Comprimir igual que la primera foto antes de enviar al backend
      let base64Image: string;
      try {
        base64Image = await comprimirImagenBase64(rawBase64 as string);
      } catch (err) {
        console.warn('Error al comprimir segunda foto, usando original:', err);
        base64Image = rawBase64 as string;
      }

      // LOG: tamaño real de la imagen comprimida
      const imgSizeKB = Math.round(base64Image.length * 0.73 / 1024);
      console.log(`[SEGUNDA FOTO] Tamaño comprimido: ~${imgSizeKB}KB`);

      const response = await fetch(`${API_BASE_URL}/objetos/analizar_imagen/`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...getAuthHeaders(),
        },
        body: JSON.stringify({
          imagen_base64: base64Image,
          solo_analisis: true,
          es_segunda_foto: true,
          motor: motorActual,  // <-- Usar el mismo motor que el usuario seleccionó
        }),
      });

      iaProgressBar.style.width = '100%';
      iaProgressPercent.textContent = '100%';

      if (!response.ok) {
        const errData = await response.json();
        throw new Error(errData.error || 'Error al analizar la segunda foto');
      }

      const result = await response.json();

      // Si se detectó ISBN, actualizar el campo
      if (result.isbn_detectado) {
        const isbnInput = document.querySelector('[name="isbn_issn"]');
        if (isbnInput) {
          isbnInput.value = result.isbn_detectado;
          window.showToast?.(`✅ ISBN detectado: ${result.isbn_detectado}`, 'success');
        }
        // Ocultar la sección de segunda foto
        if (segundaFotoSection) {
          segundaFotoSection.classList.add('hidden');
        }
        iaProgressText.textContent = '✅ ISBN capturado correctamente';
      } else {
        // Si no se detectó ISBN, intentar con los datos generales
        const datos = result.datos_ia || result;
        if (datos.isbn_issn) {
          const isbnInput = document.querySelector('[name="isbn_issn"]');
          if (isbnInput) {
            isbnInput.value = datos.isbn_issn;
            window.showToast?.(`✅ ISBN detectado: ${datos.isbn_issn}`, 'success');
          }
          if (segundaFotoSection) {
            segundaFotoSection.classList.add('hidden');
          }
          iaProgressText.textContent = '✅ ISBN capturado correctamente';
        } else {
          iaProgressText.textContent = '⚠️ No se pudo detectar el ISBN. Puedes ingresarlo manualmente.';
          window.showToast?.('⚠️ No se detectó ISBN en la parte trasera. Intenta de nuevo o ingrésalo manualmente.', 'warning');
        }
      }
    } catch (err) {
      iaProgressBar.style.width = '0%';
      iaProgressPercent.textContent = 'Error';
      iaProgressText.textContent = '❌ Error al analizar segunda foto';
      iaProgressSubtext.textContent = err.message;
      window.showToast?.(`❌ ${err.message}`, 'error');
    } finally {
      setTimeout(() => {
        iaProgressContainer.classList.add('hidden');
        analizarIaBtn.disabled = false;
        iaBtnText.classList.remove('hidden');
        iaBtnSpinner.classList.add('hidden');
      }, 3000);
    }

    e.target.value = '';
  });

  saltarSegundaFotoBtn?.addEventListener('click', () => {
    if (segundaFotoSection) {
      segundaFotoSection.classList.add('hidden');
    }
    window.showToast?.('👍 Puedes ingresar el ISBN manualmente en el campo correspondiente.', 'info');
  });

  // ===========================================================================
  // ENVÍO DEL FORMULARIO - Guardar objeto + subir foto
  // ===========================================================================
  const submitBtn = document.getElementById('submitBtn');
  const submitText = document.getElementById('submitText');
  const submitSpinner = document.getElementById('submitSpinner');

  document.getElementById('objetoForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitText.classList.add('hidden');
    submitSpinner.classList.remove('hidden');

    try {
      const formData = new FormData(e.target);

      // Construir payload del objeto
      const payload = {
        nombre: formData.get('nombre'),
        descripcion: formData.get('descripcion') || '',
        tipo: formData.get('tipo') || 'objeto',
        estado_conservacion: formData.get('estado_conservacion') || 'bueno',
        color: formData.get('color') || '',
        valor_estimado: formData.get('valor_estimado') || null,
        ubicacion: formData.get('ubicacion') || null,
        contenedor: formData.get('contenedor') || null,
        dueno_original: formData.get('dueno_original') || null,
        beneficiario: formData.get('beneficiario') || null,
      };

      // Agregar campos específicos según categoría
      const tipo = payload.tipo;
      if (tipo === 'libro') {
        payload.autor = formData.get('autor') || '';
        payload.anio = formData.get('anio') || null;
        payload.isbn_issn = formData.get('isbn_issn') || '';
        payload.edicion = formData.get('edicion') || '';
        payload.nombre_serie = formData.get('nombre_serie') || '';
        payload.titulo_tomo = formData.get('titulo_tomo') || '';
        payload.numero_tomo = formData.get('numero_tomo') || null;
        payload.editorial = formData.get('editorial') || '';
        payload.idioma = formData.get('idioma') || '';
      } else if (tipo === 'tecnologia') {
        payload.marca = formData.get('marca') || '';
        payload.modelo = formData.get('modelo') || '';
        payload.numero_serie = formData.get('numero_serie') || '';
        payload.peso = formData.get('peso') || null;
      } else if (tipo === 'mueble') {
        payload.material = formData.get('material') || '';
        payload.artista_fabricante = formData.get('artista_fabricante') || '';
        payload.largo = formData.get('largo') || null;
        payload.ancho = formData.get('ancho') || null;
        payload.alto = formData.get('alto') || null;
      } else if (tipo === 'ropa') {
        payload.tamano = formData.get('tamano') || '';
      }

      // 1. Crear el objeto
      const createResponse = await fetch(`${API_BASE_URL}/objetos/`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...getAuthHeaders(),
        },
        body: JSON.stringify(payload),
      });

      if (!createResponse.ok) {
        let errorMsg = 'Error al crear el objeto';
        try {
          const errData = await createResponse.json();
          errorMsg = errData.detail || errData.error || JSON.stringify(errData);
        } catch {
          try {
            errorMsg = await createResponse.text();
          } catch {}
        }
        throw new Error(errorMsg);
      }

      const createdObject = await createResponse.json();
      savedObjectId = createdObject.id || createdObject.data?.id;

      // 2. Subir foto si existe
      const base64Image = imagenBase64.value;
      if (base64Image && savedObjectId) {
        // Convertir Base64 a Blob para subir como multipart
        const blob = await (await fetch(base64Image)).blob();
        const formDataUpload = new FormData();
        formDataUpload.append('imagen', blob, 'foto.jpg');
        formDataUpload.append('es_principal', 'true');
        formDataUpload.append('descripcion', 'Foto principal');

        const uploadResponse = await fetch(`${API_BASE_URL}/objetos/${savedObjectId}/subir_foto/`, {
          method: 'POST',
          headers: getAuthHeaders(),
          body: formDataUpload,
        });


        if (!uploadResponse.ok) {
          console.warn('Foto subida con advertencia:', await uploadResponse.text());
        }
      }

      // 3. Limpiar sessionStorage (foto temporal) y redirigir
      try { sessionStorage.removeItem('nuevo_objeto_foto'); } catch {}
      window.showToast?.('✅ Objeto guardado correctamente', 'success');
      setTimeout(() => {
        window.location.href = `/objetos/${savedObjectId}`;
      }, 1000);

    } catch (err) {
      window.showToast?.(`❌ ${err.message}`, 'error');
      submitBtn.disabled = false;
      submitText.classList.remove('hidden');
      submitSpinner.classList.add('hidden');
    }
  });

</script>
