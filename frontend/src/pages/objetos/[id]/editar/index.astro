---
// =============================================================================
// PÁGINA DE EDICIÓN DE OBJETO (Mobile-First)
// Formulario dinámico con CategoryFields para herencia multi-tabla
// Build: 2026-07-01 — Forzar rebuild de bundle Astro
// =============================================================================

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CategoryFields from '../../../../components/CategoryFields.astro';
import AuthGuard from '../../../../components/AuthGuard.astro';
import ImageEditor from '../../../../components/ImageEditor.astro';

// Ruta dinámica: se renderiza en servidor (hybrid mode)
export const prerender = false;
---

<AuthGuard />

<BaseLayout title="Estok - Editar Objeto | Inventario">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Encabezado -->
    <div class="mb-8">
      <a
        href="/objetos"
        class="inline-flex items-center text-sm text-gray-500 hover:text-blue-700 transition-base mb-4"
      >
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver a objetos
      </a>
      <h1 class="text-3xl font-bold text-gray-900">Editar Objeto</h1>
      <p id="editSubtitle" class="mt-1 text-gray-500">
        Cargando datos del objeto...
      </p>
    </div>

    <!-- Estado de carga -->
    <div id="loadingState" class="text-center py-12">
      <svg class="animate-spin h-10 w-10 mx-auto text-blue-700 mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <p class="text-gray-500">Cargando datos del objeto...</p>
    </div>

    <!-- Estado de error -->
    <div id="errorState" class="hidden bg-red-50 border border-red-200 text-red-700 px-6 py-4 rounded-xl text-center mb-6">
      <p id="errorMessage" class="font-medium">Error al cargar el objeto.</p>
      <button id="retryBtn" class="mt-3 px-4 py-2 bg-red-100 text-red-700 rounded-lg hover:bg-red-200 transition-base text-sm font-medium">
        Reintentar
      </button>
    </div>

    <!-- Formulario -->
    <form id="objetoForm" class="hidden space-y-6" method="POST">
      <!-- ================================================================ -->
      <!-- SECCIÓN: INFORMACIÓN BÁSICA -->
      <!-- ================================================================ -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Información Básica
        </h2>

        <div class="space-y-4">
          <!-- Nombre -->
          <div>
            <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">
              Nombre <span class="text-red-500">*</span>
            </label>
            <input
              id="nombre" name="nombre" type="text" required
              placeholder="Nombre del objeto"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base"
            />
          </div>

          <!-- Descripción -->
          <div>
            <label for="descripcion" class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
            <textarea
              id="descripcion" name="descripcion" rows={3}
              placeholder="Describe el objeto (material, estado, detalles)"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base"
            ></textarea>
          </div>

          <!-- Grid: Tipo + Estado + Color + Valor -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="tipo" class="block text-sm font-medium text-gray-700 mb-1">
                Tipo <span class="text-red-500">*</span>
              </label>
              <select id="tipo" name="tipo" required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base bg-white">
                <option value="objeto">📦 Objeto Genérico</option>
                <option value="libro">📚 Libro / Revista</option>
                <option value="tecnologia">💻 Tecnología</option>
                <option value="mueble">🖼️ Mueble / Arte</option>
                <option value="ropa">👕 Ropa / Accesorio</option>
              </select>
            </div>

            <div>
              <label for="estado_conservacion" class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
              <select id="estado_conservacion" name="estado_conservacion"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base bg-white">
                <option value="excelente">Excelente</option>
                <option value="bueno" selected>Bueno</option>
                <option value="regular">Regular</option>
                <option value="malo">Malo</option>
                <option value="muy_malo">Muy malo</option>
              </select>
            </div>

            <div>
              <label for="color" class="block text-sm font-medium text-gray-700 mb-1">Color</label>
              <input id="color" name="color" type="text" placeholder="Ej: Rojo, Azul, Negro"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base" />
            </div>

            <div>
              <label for="valor_estimado" class="block text-sm font-medium text-gray-700 mb-1">Valor estimado ($)</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
                <input id="valor_estimado" name="valor_estimado" type="number" step="0.01" min="0" placeholder="0.00"
                  class="w-full pl-8 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base" />
              </div>
              <button type="button" id="estimarPrecioBtn"
                class="mt-2 inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-base disabled:opacity-50 disabled:cursor-not-allowed">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <span id="estimarPrecioText">Buscar precio de referencia</span>
                <span id="estimarPrecioSpinner" class="hidden">
                  <svg class="animate-spin h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </span>
              </button>
              <div id="precioReferencia" class="mt-2 text-xs hidden"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- ================================================================ -->
      <!-- SECCIÓN: CAMPOS ESPECÍFICOS POR CATEGORÍA (CategoryFields) -->
      <!-- ================================================================ -->
      <div id="categoryFieldsContainer">
        <CategoryFields tipo="objeto" />
      </div>

      <!-- ================================================================ -->
      <!-- SECCIÓN: UBICACIÓN Y CONTENEDOR -->
      <!-- ================================================================ -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Ubicación
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="ubicacion" class="block text-sm font-medium text-gray-700 mb-1">Ubicación</label>
            <select id="ubicacion" name="ubicacion"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base bg-white">
              <option value="">Sin ubicación</option>
            </select>
          </div>
          <div>
            <label for="contenedor" class="block text-sm font-medium text-gray-700 mb-1">Contenedor</label>
            <select id="contenedor" name="contenedor"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base bg-white">
              <option value="">Sin contenedor</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ================================================================ -->
      <!-- SECCIÓN: LEGADO Y TRAZABILIDAD -->
      <!-- ================================================================ -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Legado y Trazabilidad
        </h2>
        <p class="text-sm text-gray-400 mb-4">Dueño original y beneficiario del objeto</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="dueno_original" class="block text-sm font-medium text-gray-700 mb-1">Dueño original</label>
            <select id="dueno_original" name="dueno_original"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base bg-white">
              <option value="">Sin dueño</option>
            </select>
          </div>
          <div>
            <label for="beneficiario" class="block text-sm font-medium text-gray-700 mb-1">Beneficiario</label>
            <select id="beneficiario" name="beneficiario"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base text-base bg-white">
              <option value="">Sin beneficiario</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ================================================================ -->
      <!-- SECCIÓN: FOTOS (independiente del submit principal) -->
      <!-- ================================================================ -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Fotos
        </h2>
        <p class="text-sm text-gray-400 mb-4">Gestioná las fotos del objeto. Las acciones son independientes del guardado principal.</p>

        <!-- Fotos existentes -->
        <div id="fotosExistentes" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mb-4">
          <!-- Se llena dinámicamente -->
        </div>

        <!-- Estado vacío -->
        <div id="fotosEmpty" class="hidden text-center py-6 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300">
          <svg class="w-10 h-10 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="text-sm text-gray-400">Este objeto no tiene fotos todavía.</p>
        </div>

        <!-- Subir foto -->
        <div class="flex flex-col sm:flex-row gap-3 items-start sm:items-end">
          <div class="flex-1 w-full">
            <label class="block text-sm font-medium text-gray-700 mb-1">Agregar foto(s)</label>
            <input id="fotoInput" type="file" accept="image/jpeg,image/png,image/gif,image/webp" multiple
              class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-base cursor-pointer" />
          </div>
          <button type="button" id="subirFotosBtn" disabled
            class="px-4 py-2.5 bg-blue-700 text-white font-medium rounded-lg hover:bg-blue-800 transition-base disabled:opacity-50 disabled:cursor-not-allowed text-sm whitespace-nowrap">
            <span id="subirFotosText">📤 Subir foto(s)</span>
            <span id="subirFotosSpinner" class="hidden">
              <svg class="animate-spin h-4 w-4 mx-auto" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
              </svg>
            </span>
          </button>
        </div>
        <div id="subirFotosProgress" class="mt-2 text-sm text-gray-500 hidden"></div>
      </div>

      <!-- ================================================================ -->
      <!-- BOTÓN DE GUARDADO -->
      <!-- ================================================================ -->
      <div class="flex gap-3 pt-2">
        <button type="submit" id="saveBtn"
          class="flex-1 px-6 py-3 bg-blue-700 text-white font-medium rounded-lg hover:bg-blue-800 transition-base disabled:opacity-50 text-base shadow-sm">
          <span id="saveText">💾 Guardar Cambios</span>
          <span id="saveSpinner" class="hidden">
            <svg class="animate-spin h-5 w-5 mx-auto" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" />
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
            </svg>
          </span>
        </button>
        <a href="/objetos"
          class="flex-1 px-6 py-3 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-base text-base text-center">
          Cancelar
        </a>
      </div>
    </form>
  </div>

  <!-- Image Editor Component (Modal) -->
  <ImageEditor imageSrc="" />
</BaseLayout>

<script>
  // ===========================================================================
  // EDICIÓN DE OBJETO - Carga datos + PUT a la API
  // ===========================================================================

  const objetoId = window.location.pathname.split('/').filter(Boolean).slice(-2, -1)[0];

  const loadingState = document.getElementById('loadingState')!;
  const errorState = document.getElementById('errorState')!;
  const errorMessage = document.getElementById('errorMessage')!;
  const retryBtn = document.getElementById('retryBtn')!;
  const form = document.getElementById('objetoForm') as HTMLFormElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  const saveText = document.getElementById('saveText')!;
  const saveSpinner = document.getElementById('saveSpinner')!;
  const editSubtitle = document.getElementById('editSubtitle')!;

  import { getAuthHeaders, getToken, API_BASE_URL } from '../../../../services/auth';
  import { comprimirImagenBase64 } from '../../../../services/image';

  // ===========================================================================
  // CARGA DE DATOS DEL OBJETO
  // ===========================================================================

  async function cargarObjeto() {
    loadingState.classList.remove('hidden');
    errorState.classList.add('hidden');
    form.classList.add('hidden');

    try {
      const response = await fetch(`${API_BASE_URL}/objetos/${objetoId}/`, {
        headers: getAuthHeaders(),
      });

      if (response.status === 401) { window.location.href = '/login'; return; }
      if (!response.ok) throw new Error(`Error del servidor (${response.status})`);

      const obj = await response.json();

      // === Llenar campos básicos ===
      setFieldValue('nombre', obj.nombre);
      setFieldValue('descripcion', obj.descripcion);
      setFieldValue('tipo', obj.tipo);
      setFieldValue('estado_conservacion', obj.estado_conservacion);
      setFieldValue('color', obj.color);
      setFieldValue('valor_estimado', obj.valor_estimado);

      // === Disparar cambio de tipo para actualizar CategoryFields ===
      const tipoSelect = document.getElementById('tipo') as HTMLSelectElement;
      tipoSelect?.dispatchEvent(new Event('change'));

      // === Llenar campos específicos (herencia multi-tabla) ===
      if (obj.datos_especificos) {
        Object.entries(obj.datos_especificos).forEach(([key, value]) => {
          if (value !== null && value !== undefined && value !== '') {
            setFieldValue(key, value);
          }
        });
      }

      // === Cargar ubicaciones y contenedores, luego seleccionar valores ===
      await cargarUbicaciones(obj.ubicacion);
      await cargarContenedores(obj.ubicacion, obj.contenedor);

      // === Cargar usuarios y seleccionar dueño/beneficiario ===
      await cargarUsuarios(obj.dueno_original, obj.beneficiario);

      // === Cargar fotos ===
      await cargarFotos();

      // === Mostrar formulario ===

      editSubtitle.textContent = `Editando: ${obj.nombre}`;
      loadingState.classList.add('hidden');
      errorState.classList.add('hidden');
      form.classList.remove('hidden');

    } catch (err: any) {
      console.error('Error al cargar objeto:', err);
      loadingState.classList.add('hidden');
      errorState.classList.remove('hidden');
      errorMessage.textContent = err.message || 'Error de conexión.';
    }
  }

  function setFieldValue(fieldName: string, value: any) {
    if (value === null || value === undefined) return;
    const el = document.getElementById(fieldName) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
    if (!el) return;
    el.value = value;
    el.dispatchEvent(new Event('input', { bubbles: true }));
    el.dispatchEvent(new Event('change', { bubbles: true }));
  }

  // ===========================================================================
  // CARGA DE UBICACIONES, CONTENEDORES Y USUARIOS
  // ===========================================================================

  const ubicacionSelect = document.getElementById('ubicacion') as HTMLSelectElement;
  const contenedorSelect = document.getElementById('contenedor') as HTMLSelectElement;
  const duenoSelect = document.getElementById('dueno_original') as HTMLSelectElement;
  const beneficiarioSelect = document.getElementById('beneficiario') as HTMLSelectElement;

  async function cargarUbicaciones(selectedId?: string) {
    try {
      const res = await fetch(`${API_BASE_URL}/ubicaciones/`, { headers: getAuthHeaders() });
      if (res.ok) {
        const data = await res.json();
        const ubicaciones = data.results || data;
        ubicaciones.forEach((u: any) => {
          const opt = document.createElement('option');
          opt.value = u.id;
          opt.textContent = u.nombre;
          if (selectedId && u.id === selectedId) opt.selected = true;
          ubicacionSelect.appendChild(opt);
        });
      }
    } catch { /* ignore */ }
  }

  async function cargarContenedores(ubicacionId?: string, selectedId?: string) {
    contenedorSelect.innerHTML = '<option value="">Sin contenedor</option>';
    try {
      let url = `${API_BASE_URL}/contenedores/`;
      if (ubicacionId) url += `?ubicacion=${ubicacionId}`;
      const res = await fetch(url, { headers: getAuthHeaders() });
      if (res.ok) {
        const data = await res.json();
        const contenedores = data.results || data;
        contenedores.forEach((c: any) => {
          const opt = document.createElement('option');
          opt.value = c.id;
          opt.textContent = `${c.nombre} (${c.ubicacion_nombre || 'Sin ubicación'})`;
          if (selectedId && c.id === selectedId) opt.selected = true;
          contenedorSelect.appendChild(opt);
        });
      }
    } catch { /* ignore */ }
  }

  async function cargarUsuarios(duenoId?: string, beneficiarioId?: string) {
    try {
      const res = await fetch(`${API_BASE_URL}/usuarios/`, { headers: getAuthHeaders() });
      if (res.ok) {
        const data = await res.json();
        const usuarios = data.results || data;
        usuarios.forEach((user: any) => {
          const nombre = user.first_name
            ? `${user.first_name} ${user.last_name || ''}`
            : user.username;

          const optD = document.createElement('option');
          optD.value = user.id;
          optD.textContent = nombre;
          if (duenoId && user.id === duenoId) optD.selected = true;
          duenoSelect.appendChild(optD);

          const optB = document.createElement('option');
          optB.value = user.id;
          optB.textContent = nombre;
          if (beneficiarioId && user.id === beneficiarioId) optB.selected = true;
          beneficiarioSelect.appendChild(optB);
        });
      }
    } catch { /* ignore */ }
  }

  // Cuando cambia la ubicación, recargar contenedores
  ubicacionSelect?.addEventListener('change', () => {
    cargarContenedores(ubicacionSelect.value);
  });

  // ===========================================================================
  // MANEJO DE CATEGORÍAS (Cambio dinámico de campos)
  // ===========================================================================

  const tipoSelect = document.getElementById('tipo') as HTMLSelectElement;
  tipoSelect?.addEventListener('change', () => {
    const tipo = tipoSelect.value;
    if ((window as any).updateCategoryFields) {
      (window as any).updateCategoryFields(tipo);
    }
  });

  // ===========================================================================
  // ESTIMAR PRECIO DE REFERENCIA
  // ===========================================================================

  const estimarPrecioBtn = document.getElementById('estimarPrecioBtn');
  const estimarPrecioText = document.getElementById('estimarPrecioText');
  const estimarPrecioSpinner = document.getElementById('estimarPrecioSpinner');
  const precioReferencia = document.getElementById('precioReferencia');
  const nombreInput = document.getElementById('nombre');

  estimarPrecioBtn?.addEventListener('click', async () => {
    const nombre = nombreInput?.value?.trim();
    if (!nombre) {
      showToast('Primero escribe el nombre del objeto.', 'error');
      nombreInput?.focus();
      return;
    }
    estimarPrecioBtn.disabled = true;
    estimarPrecioText?.classList.add('hidden');
    estimarPrecioSpinner?.classList.remove('hidden');
    precioReferencia?.classList.add('hidden');
    try {
      // PASO 1: Buscar en el inventario local
      const response = await fetch(`${API_BASE_URL}/objetos/?search=${encodeURIComponent(nombre)}&ordering=-valor_estimado`, {
        headers: getAuthHeaders(),
      });
      if (response.ok) {
        const data = await response.json();
        const objetos = data.results || data;
        const conPrecio = objetos.filter((o: any) => o.valor_estimado && Number(o.valor_estimado) > 0);
        if (conPrecio.length > 0) {
          const precios = conPrecio.map((o: any) => Number(o.valor_estimado));
          const promedio = precios.reduce((a: number, b: number) => a + b, 0) / precios.length;
          const maxPrecio = Math.max(...precios);
          const minPrecio = Math.min(...precios);
          const valorEstimado = document.getElementById('valor_estimado') as HTMLInputElement;
          if (valorEstimado) {
            valorEstimado.value = promedio.toFixed(2);
            valorEstimado.dispatchEvent(new Event('input', { bubbles: true }));
          }
          if (precioReferencia) {
            precioReferencia.className = 'mt-2 text-xs text-green-600';
            precioReferencia.innerHTML = `💰 Precio sugerido: <strong>$${promedio.toFixed(2)}</strong> (rango: $${minPrecio.toFixed(2)} - $${maxPrecio.toFixed(2)}) basado en ${conPrecio.length} objeto(s) similar(es) en tu inventario.`;
            precioReferencia.classList.remove('hidden');
          }
          showToast(`💰 Precio estimado: $${promedio.toFixed(2)}`, 'success');
          return;
        }
      }

      // PASO 2: Buscar en MercadoLibre a través del backend
      try {
        const mlResponse = await fetch(`${API_BASE_URL}/objetos/buscar_precio_ml/?q=${encodeURIComponent(nombre)}`, {
          headers: getAuthHeaders(),
        });
        if (mlResponse.ok) {
          const mlData = await mlResponse.json();
          if (mlData.encontrado && mlData.precio_promedio) {
            const valorEstimado = document.getElementById('valor_estimado') as HTMLInputElement;
            if (valorEstimado) {
              valorEstimado.value = mlData.precio_promedio;
              valorEstimado.dispatchEvent(new Event('input', { bubbles: true }));
            }
            if (precioReferencia) {
              precioReferencia.className = 'mt-2 text-xs text-green-600';
              precioReferencia.innerHTML = `💰 Precio ML: <strong>$${mlData.precio_promedio}</strong> (rango: $${mlData.precio_minimo} - $${mlData.precio_maximo}) basado en ${mlData.total_resultados} publicación(es) en MercadoLibre.`;
              precioReferencia.classList.remove('hidden');
            }
            showToast(`💰 Precio de referencia: $${mlData.precio_promedio}`, 'success');
            // También abrir la pestaña de listado como referencia visual
            window.open(`https://listado.mercadolibre.com.ar/${nombre.replace(/\s+/g, '-')}`, '_blank');
            return;
          }
        }
      } catch (err) {
        console.warn('Error al buscar precio en ML:', err);
      }

      // PASO 3: Abrir MercadoLibre en nueva pestaña como referencia visual
      window.open(`https://listado.mercadolibre.com.ar/${nombre.replace(/\s+/g, '-')}`, '_blank');

      // PASO 4: Sugerencia por categoría
      const tipo = (document.getElementById('tipo') as HTMLSelectElement)?.value;
      let sugerencia = 0;
      switch (tipo) {
        case 'tecnologia': sugerencia = 150; break;
        case 'libro': sugerencia = 20; break;
        case 'mueble': sugerencia = 200; break;
        case 'ropa': sugerencia = 30; break;
        default: sugerencia = 50;
      }
      if (precioReferencia) {
        precioReferencia.className = 'mt-2 text-xs text-amber-600';
        precioReferencia.innerHTML = `💡 No se encontraron precios de referencia. Sugerencia inicial: <strong>$${sugerencia.toFixed(2)}</strong> (basado en la categoría).`;
        precioReferencia.classList.remove('hidden');
      }
      const valorEstimado = document.getElementById('valor_estimado') as HTMLInputElement;
      if (valorEstimado && !valorEstimado.value) {
        valorEstimado.value = sugerencia.toFixed(2);
      }
    } catch (err) {
      if (precioReferencia) {
        precioReferencia.className = 'mt-2 text-xs text-red-600';
        precioReferencia.textContent = '❌ Error de conexión al buscar precios.';
        precioReferencia.classList.remove('hidden');
      }
    } finally {
      estimarPrecioBtn.disabled = false;
      estimarPrecioText?.classList.remove('hidden');
      estimarPrecioSpinner?.classList.add('hidden');
    }
  });

  // ===========================================================================
  // ENVÍO DEL FORMULARIO (PUT)
  // ===========================================================================

  function showToast(message: string, type: 'success' | 'error') {
    // Delegar en el sistema de Toast global de BaseLayout
    if ((window as any).showToast) {
      (window as any).showToast(message, type);
    } else {
      // Fallback si BaseLayout no cargó (no debería ocurrir)
      const existing = document.getElementById('formToast');
      if (existing) existing.remove();
      const toast = document.createElement('div');
      toast.id = 'formToast';
      toast.className = `fixed top-4 right-4 z-50 px-6 py-3 rounded-lg shadow-lg text-white font-medium text-sm transition-all duration-300 ${
        type === 'success' ? 'bg-green-600' : 'bg-red-600'
      }`;
      toast.textContent = message;
      document.body.appendChild(toast);
      setTimeout(() => {
        toast.style.opacity = '0';
        setTimeout(() => toast.remove(), 300);
      }, 4000);
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!getToken()) {
      showToast('Debes iniciar sesión.', 'error');
      setTimeout(() => { window.location.href = '/login'; }, 1500);
      return;
    }

    saveBtn.disabled = true;
    saveText.classList.add('hidden');
    saveSpinner.classList.remove('hidden');

    try {
      const formData = new FormData(form);
      const payload: Record<string, any> = {};

      formData.forEach((value, key) => {
        if (value && value !== '') {
          payload[key] = value;
        }
      });

      // Enviar PUT a la API
      const response = await fetch(`${API_BASE_URL}/objetos/${objetoId}/`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          ...getAuthHeaders(),
        },
        body: JSON.stringify(payload),
      });

      if (response.ok) {
        showToast('✅ Objeto actualizado correctamente', 'success');
        setTimeout(() => { window.location.href = `/objetos/${objetoId}`; }, 1000);
      } else {
        const error = await response.json();
        const errorMsg = error.detail || error.error || Object.values(error).flat().join(', ');
        showToast(`❌ Error: ${errorMsg}`, 'error');
        saveBtn.disabled = false;
        saveText.classList.remove('hidden');
        saveSpinner.classList.add('hidden');
      }
    } catch (err) {
      showToast('❌ Error de conexión.', 'error');
      console.error(err);
      saveBtn.disabled = false;
      saveText.classList.remove('hidden');
      saveSpinner.classList.add('hidden');
    }
  });

  // ===========================================================================
  // GESTIÓN DE FOTOS (independiente del submit principal)
  // ===========================================================================

  const fotosExistentes = document.getElementById('fotosExistentes')!;
  const fotosEmpty = document.getElementById('fotosEmpty')!;
  const fotoInput = document.getElementById('fotoInput') as HTMLInputElement;
  const subirFotosBtn = document.getElementById('subirFotosBtn') as HTMLButtonElement;
  const subirFotosText = document.getElementById('subirFotosText')!;
  const subirFotosSpinner = document.getElementById('subirFotosSpinner')!;
  const subirFotosProgress = document.getElementById('subirFotosProgress')!;

  // Cache de fotos actuales
  let fotosActuales: any[] = [];

  function renderFotos(fotos: any[]) {
    fotosActuales = fotos;
    fotosExistentes.innerHTML = '';

    if (!fotos || fotos.length === 0) {
      fotosExistentes.classList.add('hidden');
      fotosEmpty.classList.remove('hidden');
      return;
    }

    fotosExistentes.classList.remove('hidden');
    fotosEmpty.classList.add('hidden');

    fotos.forEach((foto: any) => {
      const card = document.createElement('div');
      card.className = 'relative group bg-gray-50 rounded-lg overflow-hidden border border-gray-200';

      const img = document.createElement('img');
      img.src = foto.imagen;
      img.alt = foto.descripcion || 'Foto';
      img.className = 'w-full aspect-square object-cover';
      card.appendChild(img);

      // Badge "Principal"
      if (foto.es_principal) {
        const badge = document.createElement('div');
        badge.className = 'absolute top-1 left-1 bg-blue-600 text-white text-[10px] font-bold px-1.5 py-0.5 rounded';
        badge.textContent = '★ PRINCIPAL';
        card.appendChild(badge);
      }

      // Overlay de acciones al hover
      const overlay = document.createElement('div');
      overlay.className = 'absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center gap-2 p-2';

      // Botón "Marcar como principal"
      if (!foto.es_principal) {
        const btnPrincipal = document.createElement('button');
        btnPrincipal.className = 'w-full px-2 py-1.5 text-xs font-medium bg-yellow-500 text-white rounded hover:bg-yellow-600 transition-base';
        btnPrincipal.textContent = '★ Hacer principal';
        btnPrincipal.addEventListener('click', async () => {
          btnPrincipal.disabled = true;
          btnPrincipal.textContent = '...';
          try {
            const res = await fetch(`${API_BASE_URL}/fotos/${foto.id}/`, {
              method: 'PATCH',
              headers: {
                'Content-Type': 'application/json',
                ...getAuthHeaders(),
              },
              body: JSON.stringify({ es_principal: true }),
            });
            if (res.ok) {
              showToast('✅ Foto marcada como principal', 'success');
              // Recargar fotos
              await cargarFotos();
            } else {
              const err = await res.json().catch(() => ({}));
              showToast(`❌ Error: ${err.detail || 'No se pudo actualizar'}`, 'error');
              btnPrincipal.disabled = false;
              btnPrincipal.textContent = '★ Hacer principal';
            }
          } catch {
            showToast('❌ Error de conexión', 'error');
            btnPrincipal.disabled = false;
            btnPrincipal.textContent = '★ Hacer principal';
          }
        });
        overlay.appendChild(btnPrincipal);
      }

      // Botón "Eliminar"
      const btnEliminar = document.createElement('button');
      btnEliminar.className = 'w-full px-2 py-1.5 text-xs font-medium bg-red-600 text-white rounded hover:bg-red-700 transition-base';
      btnEliminar.textContent = '🗑️ Eliminar';
      btnEliminar.addEventListener('click', async () => {
        if (!confirm('¿Eliminar esta foto definitivamente?')) return;
        btnEliminar.disabled = true;
        btnEliminar.textContent = '...';
        try {
          const res = await fetch(`${API_BASE_URL}/fotos/${foto.id}/`, {
            method: 'DELETE',
            headers: getAuthHeaders(),
          });
          if (res.ok || res.status === 204) {
            showToast('✅ Foto eliminada', 'success');
            await cargarFotos();
          } else {
            const err = await res.json().catch(() => ({}));
            showToast(`❌ Error: ${err.detail || 'No se pudo eliminar'}`, 'error');
            btnEliminar.disabled = false;
            btnEliminar.textContent = '🗑️ Eliminar';
          }
        } catch {
          showToast('❌ Error de conexión', 'error');
          btnEliminar.disabled = false;
          btnEliminar.textContent = '🗑️ Eliminar';
        }
      });
      overlay.appendChild(btnEliminar);

      card.appendChild(overlay);
      fotosExistentes.appendChild(card);
    });
  }

  async function cargarFotos() {
    try {
      const res = await fetch(`${API_BASE_URL}/objetos/${objetoId}/`, {
        headers: getAuthHeaders(),
      });
      if (res.ok) {
        const obj = await res.json();
        renderFotos(obj.fotos || []);
      }
    } catch {
      // Silencioso - no bloquear la edición
    }
  }

  // ===========================================================================
  // SUBIR FOTO(S) CON EDICIÓN SECUENCIAL (Opción D)
  // El usuario selecciona múltiples fotos, y se van editando una por una
  // en el ImageEditor antes de subirlas.
  // ===========================================================================

  // Cola de fotos pendientes de editar
  let colaEdicion: { file: File; dataUrl: string }[] = [];
  let editandoCola = false;

  // Helper: convertir File a dataURL
  function fileToDataURL(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result as string);
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  // Helper: convertir base64 a Blob
  function base64ToBlob(base64: string, mimeType: string = 'image/jpeg'): Blob {
    const byteChars = atob(base64.split(',')[1]);
    const byteArrays: BlobPart[] = [];
    for (let offset = 0; offset < byteChars.length; offset += 512) {
      const slice = byteChars.slice(offset, offset + 512);
      const byteNumbers = new Array(slice.length);
      for (let i = 0; i < slice.length; i++) {
        byteNumbers[i] = slice.charCodeAt(i);
      }
      byteArrays.push(new Uint8Array(byteNumbers));
    }
    return new Blob(byteArrays, { type: mimeType });
  }

  // Subir una foto ya editada (base64) al servidor
  async function subirFotoEditada(base64: string, index: number, total: number, esPrimera: boolean): Promise<boolean> {
    try {
      // Comprimir la imagen antes de subirla (max 1024px, calidad 0.7)
      const comprimida = await comprimirImagenBase64(base64, 1024, 0.7);
      const blob = base64ToBlob(comprimida);
      const formData = new FormData();
      formData.append('imagen', blob, `foto_${Date.now()}.jpg`);
      formData.append('es_principal', esPrimera && fotosActuales.length === 0 ? 'true' : 'false');
      formData.append('descripcion', `Foto ${index + 1}`);

      const res = await fetch(`${API_BASE_URL}/objetos/${objetoId}/subir_foto/`, {
        method: 'POST',
        headers: getAuthHeaders(),
        body: formData,
      });

      return res.ok;
    } catch {
      return false;
    }
  }

  // Procesar la cola de edición: abre el editor para cada foto secuencialmente
  async function procesarColaEdicion() {
    if (editandoCola || colaEdicion.length === 0) return;
    editandoCola = true;

    subirFotosBtn.disabled = true;
    subirFotosText.classList.add('hidden');
    subirFotosSpinner.classList.remove('hidden');
    subirFotosProgress.classList.remove('hidden');

    let subidas = 0;
    let errores = 0;
    const total = colaEdicion.length;

    for (let i = 0; i < total; i++) {
      const item = colaEdicion[i];
      subirFotosProgress.textContent = `Editando foto ${i + 1} de ${total}...`;

      // Abrir el editor para esta foto
      let editorFn = (window as any).openImageEditor;
      if (!editorFn) {
        await new Promise(r => setTimeout(r, 500));
        editorFn = (window as any).openImageEditor;
      }
      if (!editorFn) {
        showToast('⚠️ Editor de imagen no disponible', 'error');
        errores++;
        continue;
      }

      const editedImage = await editorFn(item.dataUrl);
      if (editedImage) {
        // Subir la foto editada
        subirFotosProgress.textContent = `Subiendo foto ${i + 1} de ${total}...`;
        const ok = await subirFotoEditada(editedImage, i, total, i === 0);
        if (ok) {
          subidas++;
        } else {
          errores++;
        }
      } else {
        // Usuario canceló la edición de esta foto — no la subimos
        subirFotosProgress.textContent = `Foto ${i + 1} omitida (edición cancelada)`;
        await new Promise(r => setTimeout(r, 500));
      }
    }

    // Limpiar cola
    colaEdicion = [];
    editandoCola = false;

    // Resetear input
    fotoInput.value = '';
    subirFotosBtn.disabled = true;

    subirFotosSpinner.classList.add('hidden');
    subirFotosText.classList.remove('hidden');

    if (errores === 0 && subidas > 0) {
      subirFotosProgress.textContent = `✅ ${subidas} foto(s) subida(s) correctamente`;
      subirFotosProgress.className = 'mt-2 text-sm text-green-600';
      showToast(`✅ ${subidas} foto(s) subida(s)`, 'success');
    } else if (subidas > 0) {
      subirFotosProgress.textContent = `⚠️ ${subidas} subida(s), ${errores} error(es)`;
      subirFotosProgress.className = 'mt-2 text-sm text-amber-600';
      showToast(`⚠️ ${subidas} subida(s), ${errores} error(es)`, 'error');
    } else if (subidas === 0 && errores === 0) {
      subirFotosProgress.textContent = `ℹ️ No se subieron fotos`;
      subirFotosProgress.className = 'mt-2 text-sm text-gray-500';
    } else {
      subirFotosProgress.textContent = `❌ Error al subir las fotos`;
      subirFotosProgress.className = 'mt-2 text-sm text-red-600';
      showToast('❌ Error al subir fotos', 'error');
    }

    // Recargar fotos
    await cargarFotos();

    setTimeout(() => {
      subirFotosProgress.classList.add('hidden');
    }, 5000);
  }

  // Al seleccionar archivos, cargarlos a la cola y empezar edición
  fotoInput?.addEventListener('change', async () => {
    const files = fotoInput.files;
    if (!files || files.length === 0) return;

    // Deshabilitar el botón mientras se prepara la cola
    subirFotosBtn.disabled = true;
    subirFotosProgress.classList.remove('hidden');
    subirFotosProgress.textContent = `Preparando ${files.length} foto(s)...`;

    // Convertir todos los archivos a dataURL y agregarlos a la cola
    for (let i = 0; i < files.length; i++) {
      try {
        const dataUrl = await fileToDataURL(files[i]);
        colaEdicion.push({ file: files[i], dataUrl });
      } catch {
        console.warn(`Error leyendo archivo ${i + 1}`);
      }
    }

    if (colaEdicion.length > 0) {
      // Procesar la cola inmediatamente
      await procesarColaEdicion();
    } else {
      subirFotosProgress.classList.add('hidden');
    }
  });

  // El botón "Subir foto(s)" ahora inicia/reanuda la edición de la cola
  subirFotosBtn?.addEventListener('click', async () => {
    if (colaEdicion.length > 0) {
      await procesarColaEdicion();
    } else {
      // Si no hay cola, forzar el cambio del input
      fotoInput.click();
    }
  });

  // ===========================================================================
  // RETRY
  // ===========================================================================

  retryBtn?.addEventListener('click', cargarObjeto);

  // ===========================================================================
  // INICIALIZAR
  // ===========================================================================


  if (objetoId) {
    cargarObjeto();
  } else {
    errorMessage.textContent = 'ID de objeto no válido.';
    errorState.classList.remove('hidden');
    loadingState.classList.add('hidden');
  }
</script>
