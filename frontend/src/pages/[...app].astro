---
// =============================================================================
// Catch-all SPA Router
// Todas las rutas que no tienen página estática caen aquí
// El cliente JavaScript se encarga del routing
// =============================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthGuard from '../components/AuthGuard.astro';

// No prerenderizar - esto es un catch-all
export const prerender = false;
---

<AuthGuard />

<BaseLayout title="Estok - Inventario">
  <div id="spa-root" class="min-h-screen">
    <!-- Loading state mientras el JS decide qué renderizar -->
    <div class="flex items-center justify-center py-20">
      <svg class="animate-spin h-10 w-10 text-blue-700" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <p class="ml-3 text-gray-500">Cargando...</p>
    </div>
  </div>
</BaseLayout>

<script>
  // ===========================================================================
  // SPA Router - Redirige a la página correcta según la URL
  // ===========================================================================
  
  const path = window.location.pathname;
  
  // Detectar qué tipo de ruta es y redirigir al HTML correcto
  // Las rutas dinámicas [id] se sirven desde archivos HTML genéricos
  // que cargan los datos vía API
  
  // Si es una ruta dinámica, simplemente mostrar el contenido
  // (el HTML ya se cargó desde el catch-all)
  console.log('SPA Router - Path:', path);
</script>
