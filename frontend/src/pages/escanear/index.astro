---
// =============================================================================
// PÁGINA DE ESCÁNER QR MOBILE
// Usa la cámara del móvil para escanear QR de contenedores
// y redirige automáticamente al detalle del contenedor
// =============================================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthGuard from '../../components/AuthGuard.astro';
---

<AuthGuard />

<BaseLayout title="Estok - Escáner QR | Inventario">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Encabezado -->
    <div class="mb-8">
      <a href="/contenedores" class="inline-flex items-center text-sm text-gray-500 hover:text-blue-700 transition-base mb-4">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver a contenedores
      </a>
      <h1 class="text-3xl font-bold text-gray-900">Escáner QR</h1>
      <p class="mt-1 text-gray-500">Escanea el código QR de un contenedor para ver su contenido</p>
    </div>

    <!-- Estado: Cámara no disponible -->
    <div id="noCamera" class="hidden bg-amber-50 border border-amber-200 text-amber-700 px-6 py-4 rounded-xl text-center">
      <svg class="w-12 h-12 mx-auto mb-3 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
      <p class="font-medium mb-1">Cámara no disponible</p>
      <p class="text-sm">Tu dispositivo no tiene cámara o no diste permisos. También puedes buscar el contenedor manualmente.</p>
      <a href="/contenedores" class="mt-3 inline-block px-4 py-2 bg-amber-100 text-amber-700 rounded-lg hover:bg-amber-200 transition-base text-sm font-medium">
        Ir a contenedores
      </a>
    </div>

    <!-- Estado: Escaneando -->
    <div id="scanningState" class="text-center">
      <div class="relative bg-black rounded-xl overflow-hidden mx-auto max-w-sm mb-4">
        <video id="video" class="w-full aspect-square object-cover" autoplay playsinline muted></video>
        <!-- Marco de escaneo -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
          <div class="w-48 h-48 border-2 border-blue-400 rounded-xl opacity-70">
            <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-blue-500 rounded-tl"></div>
            <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-blue-500 rounded-tr"></div>
            <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-blue-500 rounded-bl"></div>
            <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-blue-500 rounded-br"></div>
          </div>
        </div>
        <!-- Línea de escaneo animada -->
        <div id="scanLine" class="absolute left-12 right-12 h-0.5 bg-blue-500 opacity-60 animate-scan"></div>
      </div>
      <p class="text-gray-500 text-sm">Enfoca el código QR del contenedor</p>
      <p id="scanStatus" class="text-xs text-gray-400 mt-1">Buscando QR...</p>
    </div>

    <!-- Resultado del escaneo -->
    <div id="resultState" class="hidden bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-center">
      <div id="resultSpinner" class="mb-4">
        <svg class="animate-spin h-10 w-10 mx-auto text-blue-700" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" />
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
        </svg>
      </div>
      <p id="resultText" class="text-gray-700 font-medium">QR detectado. Buscando contenedor...</p>
    </div>

    <!-- Botón para reintentar / detener -->
    <div class="text-center mt-6">
      <button id="stopBtn" class="px-6 py-3 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-base shadow-sm">
        <span id="stopText">⏹ Detener escáner</span>
      </button>
      <button id="retryScanBtn" class="hidden px-6 py-3 bg-blue-700 text-white font-medium rounded-lg hover:bg-blue-800 transition-base shadow-sm">
        🔄 Escanear otro QR
      </button>
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes scan {
    0%, 100% { top: 25%; }
    50% { top: 75%; }
  }
  .animate-scan {
    animation: scan 2s ease-in-out infinite;
  }
</style>

<script>
  // ===========================================================================
  // ESCÁNER QR - Usa jsQR para decodificar QR desde la cámara
  // ===========================================================================

  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000/api';

  const noCamera = document.getElementById('noCamera')!;
  const scanningState = document.getElementById('scanningState')!;
  const resultState = document.getElementById('resultState')!;
  const resultText = document.getElementById('resultText')!;
  const resultSpinner = document.getElementById('resultSpinner')!;
  const scanStatus = document.getElementById('scanStatus')!;
  const stopBtn = document.getElementById('stopBtn')!;
  const stopText = document.getElementById('stopText')!;
  const retryScanBtn = document.getElementById('retryScanBtn')!;
  const video = document.getElementById('video') as HTMLVideoElement;

  let stream: MediaStream | null = null;
  let animationFrameId: number | null = null;
  let scanning = false;

  import { getAuthHeaders } from '../../services/auth';




  // ===========================================================================
  // INICIAR CÁMARA
  // ===========================================================================

  async function iniciarCamara() {
    try {
      stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: 'environment', width: { ideal: 640 }, height: { ideal: 640 } },
        audio: false,
      });

      video.srcObject = stream;
      await video.play();

      noCamera.classList.add('hidden');
      scanningState.classList.remove('hidden');
      resultState.classList.add('hidden');
      stopText.textContent = '⏹ Detener escáner';
      retryScanBtn.classList.add('hidden');
      stopBtn.classList.remove('hidden');

      scanning = true;
      scanStatus.textContent = 'Buscando QR...';
      escanearQR();

    } catch (err) {
      console.error('Error al acceder a la cámara:', err);
      noCamera.classList.remove('hidden');
      scanningState.classList.add('hidden');
    }
  }

  // ===========================================================================
  // DETENER CÁMARA
  // ===========================================================================

  function detenerCamara() {
    scanning = false;
    if (animationFrameId) {
      cancelAnimationFrame(animationFrameId);
      animationFrameId = null;
    }
    if (stream) {
      stream.getTracks().forEach(track => track.stop());
      stream = null;
    }
    video.srcObject = null;
  }

  // ===========================================================================
  // ESCANEAR QR CON jsQR (cargado dinámicamente)
  // ===========================================================================

  // Cargar jsQR desde CDN
  let jsQR: any = null;

  async function cargarJsQR() {
    if (jsQR) return;
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js';
    script.async = true;
    await new Promise<void>((resolve, reject) => {
      script.onload = () => {
        jsQR = (window as any).jsQR;
        resolve();
      };
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  async function escanearQR() {
    try {
      await cargarJsQR();

      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d')!;

      function tick() {
        if (!scanning || !video.videoWidth) {
          animationFrameId = requestAnimationFrame(tick);
          return;
        }

        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const code = jsQR(imageData.data, imageData.width, imageData.height, {
          inversionAttempts: 'dontInvert',
        });

        if (code && code.data) {
          scanStatus.textContent = '✅ QR detectado!';
          procesarQR(code.data);
          return;
        }

        animationFrameId = requestAnimationFrame(tick);
      }

      tick();
    } catch (err) {
      console.error('Error al cargar jsQR:', err);
      scanStatus.textContent = '❌ Error al cargar el escáner. Intenta de nuevo.';
    }
  }

  // ===========================================================================
  // CACHE DE CONTENEDORES (para redirección instantánea)
  // ===========================================================================

  // Pre-cargar contenedores al iniciar para tenerlos en caché
  let contenedoresCache: Map<string, boolean> = new Map();
  let cacheLoaded = false;

  async function precargarContenedores() {
    if (cacheLoaded) return;
    try {
      const res = await fetch(`${API_URL}/contenedores/?limit=100`, {
        headers: getAuthHeaders(),
      });
      if (res.ok) {
        const data = await res.json();
        const contenedores = data.results || data;
        contenedores.forEach((c: any) => {
          contenedoresCache.set(c.id, true);
        });
        cacheLoaded = true;
        console.log(`📦 Precargados ${contenedoresCache.size} contenedores en caché`);
      }
    } catch (err) {
      console.warn('No se pudo precargar caché de contenedores:', err);
    }
  }

  // Iniciar precarga inmediatamente
  precargarContenedores();

  // ===========================================================================
  // PROCESAR QR ESCANEADO (REDIRECCIÓN INSTANTÁNEA)
  // ===========================================================================

  async function procesarQR(qrData: string) {
    scanning = false;
    if (animationFrameId) {
      cancelAnimationFrame(animationFrameId);
      animationFrameId = null;
    }

    // Mostrar estado de procesamiento
    scanningState.classList.add('hidden');
    resultState.classList.remove('hidden');
    resultSpinner.classList.remove('hidden');
    resultText.textContent = 'QR detectado. Buscando contenedor...';

    try {
      // Intentar parsear el QR como JSON con ID de contenedor
      let contenedorId: string | null = null;

      try {
        const parsed = JSON.parse(qrData);
        contenedorId = parsed.contenedor_id || parsed.id || null;
      } catch {
        // Si no es JSON, asumir que es un UUID directo
        if (qrData.match(/^[0-9a-f-]{36}$/i)) {
          contenedorId = qrData;
        }
      }

      if (contenedorId) {
        // REDIRECCIÓN INSTANTÁNEA: Si está en caché, redirigir sin esperar verificación
        if (contenedoresCache.has(contenedorId)) {
          resultSpinner.classList.add('hidden');
          resultText.innerHTML = `✅ Contenedor en caché. Redirigiendo...`;
          // Redirección inmediata (sin setTimeout)
          window.location.href = `/contenedores/${contenedorId}`;
          return;
        }

        // Verificar que el contenedor existe (con timeout corto)
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 3000);
        const res = await fetch(`${API_URL}/contenedores/${contenedorId}/`, {
          headers: getAuthHeaders(),
          signal: controller.signal,
        });
        clearTimeout(timeoutId);

        if (res.ok) {
          resultSpinner.classList.add('hidden');
          resultText.innerHTML = `✅ Contenedor encontrado. Redirigiendo...`;
          // Redirección rápida (sin espera)
          window.location.href = `/contenedores/${contenedorId}`;
          return;
        }
      }

      // Si no se pudo identificar, intentar con el endpoint de escaneo
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 5000);
      const res = await fetch(`${API_URL}/contenedores/escanear/?qr_data=${encodeURIComponent(qrData)}`, {
        headers: getAuthHeaders(),
        signal: controller.signal,
      });
      clearTimeout(timeoutId);

      if (res.ok) {
        const data = await res.json();
        if (data.contenedor?.id) {
          resultSpinner.classList.add('hidden');
          resultText.innerHTML = `✅ Contenedor encontrado. Redirigiendo...`;
          window.location.href = `/contenedores/${data.contenedor.id}`;
          return;
        }
      }

      // No encontrado
      resultSpinner.classList.add('hidden');
      resultText.innerHTML = '❌ No se encontró un contenedor con este código QR.';
      stopBtn.classList.add('hidden');
      retryScanBtn.classList.remove('hidden');

    } catch (err) {
      console.error('Error al procesar QR:', err);
      resultSpinner.classList.add('hidden');
      resultText.innerHTML = '❌ Error al procesar el código QR.';
      stopBtn.classList.add('hidden');
      retryScanBtn.classList.remove('hidden');
    }
  }


  // ===========================================================================
  // CONTROLES
  // ===========================================================================

  stopBtn?.addEventListener('click', () => {
    detenerCamara();
    scanningState.classList.add('hidden');
    resultState.classList.remove('hidden');
    resultSpinner.classList.add('hidden');
    resultText.textContent = '🔴 Escáner detenido.';
    stopBtn.classList.add('hidden');
    retryScanBtn.classList.remove('hidden');
  });

  retryScanBtn?.addEventListener('click', () => {
    resultState.classList.add('hidden');
    retryScanBtn.classList.add('hidden');
    stopBtn.classList.remove('hidden');
    iniciarCamara();
  });

  // ===========================================================================
  // INICIALIZAR
  // ===========================================================================

  // Verificar soporte de cámara
  if (!navigator.mediaDevices?.getUserMedia) {
    noCamera.classList.remove('hidden');
    scanningState.classList.add('hidden');
  } else {
    iniciarCamara();
  }

  // Limpiar al salir
  window.addEventListener('beforeunload', detenerCamara);
</script>
