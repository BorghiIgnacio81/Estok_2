---
// =============================================================================
// PÁGINA DE LISTADO DE OBJETOS (Dinámico con API)
// =============================================================================

import BaseLayout from '../layouts/BaseLayout.astro';
import AuthGuard from '../components/AuthGuard.astro';
import LoadingState from '../components/LoadingState.astro';
import ErrorState from '../components/ErrorState.astro';
import EmptyState from '../components/EmptyState.astro';
---

<AuthGuard />

<BaseLayout title="Estok - Objetos | Inventario">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Objetos</h1>
        <p class="mt-1 text-gray-500">Gestiona todos los objetos de tu inventario</p>
      </div>
      <div class="flex gap-2">
        <button id="exportCsvBtn" class="inline-flex items-center px-3 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition-base shadow-sm">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Exportar CSV
        </button>
        <a
          href="/objetos/nuevo"
          class="inline-flex items-center px-4 py-2 bg-blue-700 text-white font-medium rounded-lg hover:bg-blue-800 transition-base shadow-sm"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Nuevo Objeto
        </a>
      </div>
    </div>

    <!-- Barra de búsqueda -->
    <div class="mb-6">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="searchInput"
          type="text"
          placeholder="Buscar objetos por nombre o descripción..."
          class="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-base"
        />
      </div>
    </div>


    <!-- Filtros por categoría -->
    <div class="flex flex-wrap gap-3 mb-8" id="filtrosContainer">
      <button data-tipo="" class="filtro-btn px-4 py-2 bg-blue-700 text-white text-sm font-medium rounded-full transition-base">
        Todos
      </button>
      <button data-tipo="libro" class="filtro-btn px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-full hover:bg-blue-50 hover:text-blue-700 transition-base">
        📚 Libros
      </button>
      <button data-tipo="tecnologia" class="filtro-btn px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-full hover:bg-green-50 hover:text-green-700 transition-base">
         Tecnología
      </button>
      <button data-tipo="mueble" class="filtro-btn px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-full hover:bg-amber-50 hover:text-amber-700 transition-base">
        🖼️ Muebles / Arte
      </button>
      <button data-tipo="ropa" class="filtro-btn px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-full hover:bg-purple-50 hover:text-purple-700 transition-base">
        👕 Ropa
      </button>
    </div>

    <LoadingState mensaje="Cargando objetos..." />
    <ErrorState mensaje="Error al cargar objetos." />
    <EmptyState
      titulo="No hay objetos registrados"
      descripcion="Comienza agregando tu primer objeto al inventario."
      icono="📦"
      accionTexto="Agregar Primer Objeto"
      accionHref="/objetos/nuevo"
    />

    <!-- Grid de objetos -->
    <div id="objetosGrid" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
  </div>
</BaseLayout>

<script>
  // ===========================================================================
  // LISTADO DINÁMICO DE OBJETOS
  // ===========================================================================

  import {getAuthHeaders, API_BASE_URL} from '../services/auth';

  

  const loadingState = document.getElementById('loadingState')!;
  const emptyState = document.getElementById('emptyState')!;
  const errorState = document.getElementById('errorState')!;
  const errorMessage = document.getElementById('errorMessage')!;
  const retryBtn = document.getElementById('retryBtn')!;
  const objetosGrid = document.getElementById('objetosGrid')!;
  const filtrosContainer = document.getElementById('filtrosContainer')!;

  let currentTipo = '';


  function showLoading() {
    loadingState.classList.remove('hidden');
    emptyState.classList.add('hidden');
    errorState.classList.add('hidden');
    objetosGrid.classList.add('hidden');
  }

  function showError(msg: string) {
    loadingState.classList.add('hidden');
    emptyState.classList.add('hidden');
    errorState.classList.remove('hidden');
    objetosGrid.classList.add('hidden');
    errorMessage.textContent = msg;
  }

  function getEstadoBadge(estado: string): string {
    const map: Record<string, { color: string; label: string }> = {
      excelente: { color: 'bg-green-100 text-green-700', label: 'Excelente' },
      bueno: { color: 'bg-blue-100 text-blue-700', label: 'Bueno' },
      regular: { color: 'bg-yellow-100 text-yellow-700', label: 'Regular' },
      malo: { color: 'bg-orange-100 text-orange-700', label: 'Malo' },
      muy_malo: { color: 'bg-red-100 text-red-700', label: 'Muy malo' },
    };
    const info = map[estado] || { color: 'bg-gray-100 text-gray-700', label: estado };
    return `<span class="text-xs px-2 py-1 rounded-full font-medium ${info.color}">${info.label}</span>`;
  }

  function getTipoIcon(tipo: string): string {
    const map: Record<string, string> = {
      libro: '📚',
      tecnologia: '💻',
      mueble: '🖼️',
      ropa: '👕',
      objeto: '📦',
    };
    return map[tipo] || '📦';
  }

  function getEstadoCargaBadge(estado: string): string {
    if (estado === 'completo') {
      return '<span class="text-xs text-green-600 font-medium">✅ Completo</span>';
    } else if (estado === 'incompleto') {
      return '<span class="text-xs text-yellow-600 font-medium">⚠️ Incompleto</span>';
    }
    return '<span class="text-xs text-gray-400 font-medium">⏳ Pendiente IA</span>';
  }

  function renderObjetos(objetos: any[]) {
    if (objetos.length === 0) {
      loadingState.classList.add('hidden');
      errorState.classList.add('hidden');
      objetosGrid.classList.add('hidden');
      emptyState.classList.remove('hidden');
      return;
    }

    loadingState.classList.add('hidden');
    errorState.classList.add('hidden');
    emptyState.classList.add('hidden');
    objetosGrid.classList.remove('hidden');

    objetosGrid.innerHTML = objetos.map((obj) => {
      const fotoUrl = obj.foto_principal || '';
      const tipoIcon = getTipoIcon(obj.tipo);
      const estadoBadge = getEstadoBadge(obj.estado_conservacion);
      const cargaBadge = getEstadoCargaBadge(obj.estado_carga);
      const valor = obj.valor_estimado
        ? `$${parseFloat(obj.valor_estimado).toLocaleString('es-AR', { minimumFractionDigits: 2 })}`
        : '—';

      return `
        <div class="objeto-card bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-base cursor-pointer" data-id="${obj.id}" data-href="/objetos/${obj.id}">
          <!-- Foto -->
          <div class="h-40 bg-gray-100 flex items-center justify-center overflow-hidden">
            ${fotoUrl
              ? `<img src="${fotoUrl}" alt="${obj.nombre}" class="w-full h-full object-cover" />`
              : `<div class="text-center text-gray-400"><span class="text-4xl">${tipoIcon}</span><p class="text-xs mt-1">Sin foto</p></div>`
            }
          </div>
          <!-- Info -->
          <div class="p-4">
            <div class="flex items-start justify-between gap-2 mb-2">
              <h3 class="font-semibold text-gray-900 text-sm leading-tight line-clamp-2">${obj.nombre}</h3>
              <span class="text-lg flex-shrink-0">${tipoIcon}</span>
            </div>
            <div class="flex flex-wrap gap-1.5 mb-2">
              ${estadoBadge}
              ${cargaBadge}
            </div>
            <div class="text-xs text-gray-500 space-y-1">
              ${obj.ubicacion_nombre ? `<p>📍 ${obj.ubicacion_nombre}</p>` : ''}
              ${obj.contenedor_nombre ? `<p>📦 ${obj.contenedor_nombre}</p>` : ''}
              <p class="font-medium text-gray-700">💰 ${valor}</p>
            </div>
            <p class="text-xs text-gray-400 mt-2">${new Date(obj.fecha_registro).toLocaleDateString('es-AR')}</p>
          </div>
          <!-- Botones de acción -->
          <div class="flex border-t border-gray-100 divide-x divide-gray-100">
            <a href="/objetos/${obj.id}/editar" class="editar-link flex-1 flex items-center justify-center gap-1.5 py-2.5 text-sm font-medium text-blue-600 hover:bg-blue-50 transition-base">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              Editar
            </a>
            <button class="delete-btn flex-1 flex items-center justify-center gap-1.5 py-2.5 text-sm font-medium text-red-600 hover:bg-red-50 transition-base" data-id="${obj.id}" data-nombre="${obj.nombre}">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              Eliminar
            </button>
          </div>
        </div>
      `;
    }).join('');

    // Click en card para ver detalle (usando event delegation)
    // Botones eliminar
    objetosGrid.querySelectorAll('.delete-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = btn.getAttribute('data-id');
        const nombre = btn.getAttribute('data-nombre');
        if (!id) return;
        if (!confirm(`¿Estás seguro de eliminar "${nombre}"? Se marcará como eliminado.`)) return;
        try {
          const res = await fetch(`${API_BASE_URL}/objetos/${id}/`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
              ...getAuthHeaders(),
            },
          });
          if (res.ok || res.status === 204) {
            (window as any).showSuccess?.(`✅ "${nombre}" eliminado`);
            cargarObjetos(currentTipo);
          } else {
            const err = await res.json().catch(() => ({}));
            (window as any).showError?.(`❌ Error al eliminar: ${err.detail || err.error || 'Error desconocido'}`);
          }
        } catch {
          (window as any).showError?.('❌ Error de conexión');
        }
      });
    });

    // Navegación al hacer clic en la tarjeta (excepto en botones/links)
    objetosGrid.querySelectorAll('.objeto-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        // No navegar si el clic fue en un enlace o botón
        const target = e.target as HTMLElement;
        if (target.closest('a') || target.closest('button')) return;
        const href = card.getAttribute('data-href');
        if (href) window.location.href = href;
      });
    });
  }

  async function cargarObjetos(tipo: string = '') {
    showLoading();

    try {
      let url = `${API_BASE_URL}/objetos/?page_size=50`;
      if (tipo) url += `&tipo=${tipo}`;

      const response = await fetch(url, { headers: getAuthHeaders() });

      if (response.status === 401) {
        window.location.href = '/login';
        return;
      }

      if (!response.ok) {
        showError(`Error del servidor (${response.status})`);
        return;
      }

      const data = await response.json();
      const objetos = data.results || data;
      renderObjetos(objetos);
    } catch (err) {
      console.error('Error al cargar objetos:', err);
      showError('Error de conexión. Verifica que el servidor esté corriendo.');
    }
  }

  // Filtros
  filtrosContainer?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.filtro-btn') as HTMLElement;
    if (!btn) return;

    const tipo = btn.getAttribute('data-tipo') || '';
    currentTipo = tipo;

    // Actualizar estilo de botones
    filtrosContainer.querySelectorAll('.filtro-btn').forEach((b) => {
      b.className = 'filtro-btn px-4 py-2 text-sm font-medium rounded-full transition-base';
      if (b === btn) {
        b.classList.add('bg-blue-700', 'text-white');
      } else {
        b.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-blue-50', 'hover:text-blue-700');
      }
    });

    cargarObjetos(tipo);
  });

  // Retry
  retryBtn?.addEventListener('click', () => cargarObjetos(currentTipo));

  // ===========================================================================
  // BÚSQUEDA EN TIEMPO REAL
  // ===========================================================================

  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  let searchTimeout: number | null = null;

  searchInput?.addEventListener('input', () => {
    if (searchTimeout) clearTimeout(searchTimeout);
    searchTimeout = window.setTimeout(() => {
      const query = searchInput.value.trim();
      if (query.length > 0 && query.length < 2) return;

      showLoading();
      let url = `${API_BASE_URL}/objetos/?page_size=50`;
      if (currentTipo) url += `&tipo=${currentTipo}`;
      if (query) url += `&search=${encodeURIComponent(query)}`;

      fetch(url, { headers: getAuthHeaders() })
        .then(r => r.json())
        .then(data => renderObjetos(data.results || data))
        .catch(() => showError('Error al buscar.'));
    }, 300);
  });

  // ===========================================================================
  // EXPORTAR CSV
  // ===========================================================================

  document.getElementById('exportCsvBtn')?.addEventListener('click', async () => {
    try {
      const response = await fetch(`${API_BASE_URL}/objetos/exportar_csv/`, {
        headers: getAuthHeaders(),
      });

      if (!response.ok) {
        (window as any).showError?.('Error al exportar CSV');
        return;
      }

      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `inventario_estok_${new Date().toISOString().split('T')[0]}.csv`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      window.URL.revokeObjectURL(url);
      (window as any).showSuccess?.('✅ CSV exportado correctamente');
    } catch {
      (window as any).showError?.('Error de conexión al exportar CSV');
    }
  });

  // Cargar al inicio
  cargarObjetos();
</script>


