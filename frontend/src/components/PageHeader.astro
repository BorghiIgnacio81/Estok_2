---
// =============================================================================
// COMPONENTE: PageHeader
// Encabezado de página con título, descripción y acciones
// =============================================================================

export interface Props {
  titulo: string;
  descripcion?: string;
}

const { titulo, descripcion } = Astro.props;
---

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">{titulo}</h1>
  {descripcion && <p class="mt-1 text-gray-500">{descripcion}</p>}
</div>
