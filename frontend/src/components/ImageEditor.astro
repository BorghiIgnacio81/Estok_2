---
// =============================================================================
// COMPONENTE ImageEditor - Editor de imagen con Canvas API
// Permite rotar, ajustar brillo y recortar con rectángulo libre
// (selección manual con arrastre + manijas de redimensionamiento)
// =============================================================================

export interface Props {
  imageSrc: string;
}

const { imageSrc } = Astro.props;
---

<div id="imageEditor" class="hidden fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-xl shadow-xl max-w-3xl w-full max-h-[90vh] overflow-y-auto">
    <!-- Encabezado -->
    <div class="flex items-center justify-between p-4 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-900">✏️ Editar Imagen</h3>
      <button id="closeEditorBtn" class="text-gray-400 hover:text-gray-600 p-1">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Canvas de edición -->
    <div class="p-4 bg-gray-100 flex items-center justify-center min-h-[300px] relative">
      <canvas id="editorCanvas" class="max-w-full max-h-[55vh] rounded-lg shadow-inner" style="cursor: crosshair;"></canvas>
      <!-- Instrucciones flotantes -->
      <div id="cropInstructions" class="absolute bottom-6 left-1/2 -translate-x-1/2 bg-black/70 text-white text-xs px-3 py-1.5 rounded-full pointer-events-none opacity-0 transition-opacity duration-300">
        Arrastrá para seleccionar área de recorte · Usá las manijas para ajustar
      </div>
    </div>

    <!-- Controles de edición -->
    <div class="p-4 space-y-4">
      <!-- Brillo -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2">
          <svg class="w-4 h-4 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          Brillo
        </label>
        <input id="brightnessSlider" type="range" min="-100" max="100" value="0"
          class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue-700" />
        <div class="flex justify-between text-xs text-gray-400 mt-1">
          <span>-100</span>
          <span id="brightnessValue" class="font-medium text-gray-600">0</span>
          <span>+100</span>
        </div>
      </div>

      <!-- Rotación -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Rotar</label>
        <div class="flex gap-2">
          <button id="rotateLeftBtn" type="button"
            class="flex-1 flex items-center justify-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-base">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            ↺ Rotar Izquierda
          </button>
          <button id="rotateRightBtn" type="button"
            class="flex-1 flex items-center justify-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-base">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            ↻ Rotar Derecha
          </button>
        </div>
      </div>

      <!-- Recorte Libre -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2">
          <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Recorte
        </label>
        <div class="flex flex-wrap gap-2">
          <button id="cropToggleBtn" type="button"
            class="px-4 py-2 bg-blue-700 text-white text-sm font-medium rounded-lg transition-base flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            <span id="cropBtnText">Activar Recorte</span>
          </button>
          <button id="resetCropBtn" type="button" disabled
            class="px-4 py-2 bg-gray-100 text-gray-400 text-sm font-medium rounded-lg transition-base disabled:opacity-50 disabled:cursor-not-allowed">
            ↺ Quitar Recorte
          </button>
        </div>
        <p class="text-xs text-gray-400 mt-2">
          💡 Arrastrá sobre la imagen para crear un rectángulo de recorte.
          Después podés moverlo y redimensionarlo con las manijas en las esquinas.
        </p>
      </div>

      <!-- Botones de acción -->
      <div class="flex gap-3 pt-2 border-t border-gray-200">
        <button id="resetEditorBtn" type="button"
          class="flex-1 px-4 py-2.5 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-base">
          ↺ Restablecer todo
        </button>
        <button id="applyEditorBtn" type="button"
          class="flex-1 px-4 py-2.5 bg-blue-700 text-white font-medium rounded-lg hover:bg-blue-800 transition-base shadow-sm">
          ✅ Aplicar Cambios
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // ===========================================================================
  // IMAGE EDITOR - Canvas API (Rotar, Brillo, Recorte Libre con manijas)
  // ===========================================================================

  const editor = document.getElementById('imageEditor') as HTMLElement;
  const canvas = document.getElementById('editorCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const brightnessSlider = document.getElementById('brightnessSlider') as HTMLInputElement;
  const brightnessValue = document.getElementById('brightnessValue') as HTMLElement;
  const rotateLeftBtn = document.getElementById('rotateLeftBtn') as HTMLElement;
  const rotateRightBtn = document.getElementById('rotateRightBtn') as HTMLElement;
  const resetBtn = document.getElementById('resetEditorBtn') as HTMLElement;
  const applyBtn = document.getElementById('applyEditorBtn') as HTMLElement;
  const closeBtn = document.getElementById('closeEditorBtn') as HTMLElement;
  const cropToggleBtn = document.getElementById('cropToggleBtn') as HTMLElement;
  const cropBtnText = document.getElementById('cropBtnText') as HTMLElement;
  const resetCropBtn = document.getElementById('resetCropBtn') as HTMLButtonElement;
  const cropInstructions = document.getElementById('cropInstructions') as HTMLElement;

  let originalImage: HTMLImageElement | null = null;
  let baseImage: HTMLImageElement | null = null; // copia inalterable para reset
  let currentRotation = 0;
  let currentBrightness = 0;
  let isCropping = false; // modo recorte activo

  // Estado del rectángulo de recorte (en coordenadas del canvas)
  let cropRect = { x: 0, y: 0, w: 0, h: 0 };
  let hasCrop = false;

  // Estados de interacción
  type DragMode = 'none' | 'creating' | 'moving' | 'resize-tl' | 'resize-tr' | 'resize-bl' | 'resize-br';
  let dragMode: DragMode = 'none';
  let dragStartX = 0, dragStartY = 0;
  let dragOrigRect = { x: 0, y: 0, w: 0, h: 0 };

  const HANDLE_SIZE = 10;
  const MIN_CROP_SIZE = 20;

  // ===========================================================================
  // ABRIR EDITOR
  // ===========================================================================

  async function openEditor(imageSrc: string): Promise<string | null> {
    return new Promise<string | null>((resolve) => {
      (window as any)._editorResolve = resolve;

      const img = new Image();
      img.onload = () => {
        originalImage = img;
        // Guardar copia inalterable para reset
        baseImage = img;
        currentRotation = 0;
        currentBrightness = 0;
        isCropping = false;
        hasCrop = false;
        cropRect = { x: 0, y: 0, w: 0, h: 0 };
        brightnessSlider.value = '0';
        brightnessValue.textContent = '0';
        cropBtnText.textContent = 'Activar Recorte';
        cropToggleBtn.className = 'px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg transition-base flex items-center gap-2';
        resetCropBtn.disabled = true;
        cropInstructions.classList.add('opacity-0');

        renderImage();
        editor.classList.remove('hidden');
      };
      img.onerror = () => {
        console.error('Error al cargar imagen en el editor');
        resolve(null);
      };
      img.src = imageSrc;
    });
  }

  // ===========================================================================
  // RENDERIZAR IMAGEN EN CANVAS
  // ===========================================================================

  function renderImage() {
    if (!originalImage) return;

    const maxWidth = 700;
    const maxHeight = 550;
    const imgW = originalImage.width;
    const imgH = originalImage.height;

    // La imagen ya está rotada (bake), así que no hay rotación pendiente.
    // currentRotation siempre es 0 aquí.
    let scale = 1;
    if (imgW > maxWidth) scale = maxWidth / imgW;
    if (imgH * scale > maxHeight) scale = maxHeight / imgH;

    const canvasW = Math.round(imgW * scale);
    const canvasH = Math.round(imgH * scale);

    canvas.width = canvasW;
    canvas.height = canvasH;

    ctx.clearRect(0, 0, canvasW, canvasH);

    // Aplicar brillo
    ctx.filter = `brightness(${1 + currentBrightness / 100})`;
    ctx.drawImage(originalImage, 0, 0, canvasW, canvasH);
    ctx.filter = 'none';

    // Dibujar overlay de recorte si está activo
    if (isCropping && hasCrop && cropRect.w > 0 && cropRect.h > 0) {
      drawCropOverlay();
    }
  }

  function drawCropOverlay() {
    const { x, y, w, h } = cropRect;

    // Oscurecer fuera del recorte
    ctx.fillStyle = 'rgba(0, 0, 0, 0.55)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // "Recortar" el área seleccionada (limpiar el rectángulo)
    ctx.clearRect(x, y, w, h);

    // Volver a dibujar SOLO la parte de la imagen dentro del recorte
    ctx.save();
    ctx.beginPath();
    ctx.rect(x, y, w, h);
    ctx.clip();

    ctx.filter = `brightness(${1 + currentBrightness / 100})`;
    const imgW = originalImage!.width;
    const imgH = originalImage!.height;
    const maxWidth = 700, maxHeight = 550;
    let scale = 1;
    if (imgW > maxWidth) scale = maxWidth / imgW;
    if (imgH * scale > maxHeight) scale = maxHeight / imgH;
    const canvasW = Math.round(imgW * scale);
    const canvasH = Math.round(imgH * scale);

    ctx.drawImage(originalImage!, 0, 0, canvasW, canvasH);
    ctx.filter = 'none';
    ctx.restore();

    // Borde del recorte
    ctx.strokeStyle = '#3b82f6';
    ctx.lineWidth = 2.5;
    ctx.setLineDash([]);
    ctx.strokeRect(x, y, w, h);

    // Líneas de guía (regla de tercios)
    ctx.strokeStyle = 'rgba(59, 130, 246, 0.3)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    // Verticales
    ctx.beginPath();
    ctx.moveTo(x + w / 3, y);
    ctx.lineTo(x + w / 3, y + h);
    ctx.moveTo(x + 2 * w / 3, y);
    ctx.lineTo(x + 2 * w / 3, y + h);
    // Horizontales
    ctx.moveTo(x, y + h / 3);
    ctx.lineTo(x + w, y + h / 3);
    ctx.moveTo(x, y + 2 * h / 3);
    ctx.lineTo(x + w, y + 2 * h / 3);
    ctx.stroke();
    ctx.setLineDash([]);

    // Manijas en las esquinas
    drawHandle(x, y, 'tl');
    drawHandle(x + w, y, 'tr');
    drawHandle(x, y + h, 'bl');
    drawHandle(x + w, y + h, 'br');
  }

  function drawHandle(hx: number, hy: number, _pos: string) {
    const s = HANDLE_SIZE;
    ctx.fillStyle = '#ffffff';
    ctx.strokeStyle = '#3b82f6';
    ctx.lineWidth = 2;
    ctx.shadowColor = 'rgba(0,0,0,0.3)';
    ctx.shadowBlur = 4;
    ctx.fillRect(hx - s / 2, hy - s / 2, s, s);
    ctx.shadowBlur = 0;
    ctx.strokeRect(hx - s / 2, hy - s / 2, s, s);
  }

  // ===========================================================================
  // UTILIDAD: Obtener posición del mouse/touch en coordenadas del canvas
  // ===========================================================================

  function getCanvasPos(e: MouseEvent | Touch): { x: number; y: number } {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    return {
      x: (e.clientX - rect.left) * scaleX,
      y: (e.clientY - rect.top) * scaleY,
    };
  }

  // ===========================================================================
  // DETECTAR MODO DE INTERACCIÓN SEGÚN POSICIÓN
  // ===========================================================================

  function getInteractionMode(pos: { x: number; y: number }): DragMode {
    if (!isCropping || !hasCrop || cropRect.w === 0) return 'none';

    const { x, y, w, h } = cropRect;
    const s = HANDLE_SIZE + 4; // zona de tolerancia

    // Esquinas (prioridad más alta)
    if (Math.abs(pos.x - x) < s && Math.abs(pos.y - y) < s) return 'resize-tl';
    if (Math.abs(pos.x - (x + w)) < s && Math.abs(pos.y - y) < s) return 'resize-tr';
    if (Math.abs(pos.x - x) < s && Math.abs(pos.y - (y + h)) < s) return 'resize-bl';
    if (Math.abs(pos.x - (x + w)) < s && Math.abs(pos.y - (y + h)) < s) return 'resize-br';

    // Dentro del rectángulo → mover
    if (pos.x >= x && pos.x <= x + w && pos.y >= y && pos.y <= y + h) {
      return 'moving';
    }

    return 'none';
  }

  // ===========================================================================
  // MOUSE EVENTS
  // ===========================================================================

  canvas.addEventListener('mousedown', (e) => {
    const pos = getCanvasPos(e);

    if (isCropping && hasCrop) {
      const mode = getInteractionMode(pos);
      if (mode !== 'none') {
        dragMode = mode;
        dragStartX = pos.x;
        dragStartY = pos.y;
        dragOrigRect = { ...cropRect };
        return;
      }
    }

    if (isCropping) {
      // Iniciar creación de nuevo rectángulo
      dragMode = 'creating';
      dragStartX = pos.x;
      dragStartY = pos.y;
      cropRect = { x: pos.x, y: pos.y, w: 0, h: 0 };
      hasCrop = true;
    }
  });

  canvas.addEventListener('mousemove', (e) => {
    const pos = getCanvasPos(e);

    if (dragMode === 'none' && isCropping) {
      // Cambiar cursor según contexto
      const mode = getInteractionMode(pos);
      switch (mode) {
        case 'resize-tl': case 'resize-br': canvas.style.cursor = 'nwse-resize'; break;
        case 'resize-tr': case 'resize-bl': canvas.style.cursor = 'nesw-resize'; break;
        case 'moving': canvas.style.cursor = 'move'; break;
        default: canvas.style.cursor = isCropping ? 'crosshair' : 'default';
      }
      return;
    }

    if (dragMode === 'creating') {
      let nx = Math.min(dragStartX, pos.x);
      let ny = Math.min(dragStartY, pos.y);
      let nw = Math.abs(pos.x - dragStartX);
      let nh = Math.abs(pos.y - dragStartY);
      if (nw < MIN_CROP_SIZE) nw = MIN_CROP_SIZE;
      if (nh < MIN_CROP_SIZE) nh = MIN_CROP_SIZE;
      cropRect = { x: nx, y: ny, w: nw, h: nh };
      hasCrop = true;
      renderImage();
      return;
    }

    if (dragMode === 'moving') {
      const dx = pos.x - dragStartX;
      const dy = pos.y - dragStartY;
      let nx = dragOrigRect.x + dx;
      let ny = dragOrigRect.y + dy;
      // Limitar dentro del canvas
      nx = Math.max(0, Math.min(nx, canvas.width - cropRect.w));
      ny = Math.max(0, Math.min(ny, canvas.height - cropRect.h));
      cropRect.x = nx;
      cropRect.y = ny;
      renderImage();
      return;
    }

    // Redimensionar desde esquinas
    if (dragMode.startsWith('resize-')) {
      const dx = pos.x - dragStartX;
      const dy = pos.y - dragStartY;
      let { x, y, w, h } = dragOrigRect;

      switch (dragMode) {
        case 'resize-tl':
          x = dragOrigRect.x + dx;
          y = dragOrigRect.y + dy;
          w = dragOrigRect.w - dx;
          h = dragOrigRect.h - dy;
          break;
        case 'resize-tr':
          y = dragOrigRect.y + dy;
          w = dragOrigRect.w + dx;
          h = dragOrigRect.h - dy;
          break;
        case 'resize-bl':
          x = dragOrigRect.x + dx;
          w = dragOrigRect.w - dx;
          h = dragOrigRect.h + dy;
          break;
        case 'resize-br':
          w = dragOrigRect.w + dx;
          h = dragOrigRect.h + dy;
          break;
      }

      // Asegurar tamaño mínimo
      if (w < MIN_CROP_SIZE) w = MIN_CROP_SIZE;
      if (h < MIN_CROP_SIZE) h = MIN_CROP_SIZE;

      // Ajustar posición si se invierte
      if (w < 0) { x = x + w; w = Math.abs(w); }
      if (h < 0) { y = y + h; h = Math.abs(h); }

      // Limitar dentro del canvas
      x = Math.max(0, x);
      y = Math.max(0, y);
      if (x + w > canvas.width) w = canvas.width - x;
      if (y + h > canvas.height) h = canvas.height - y;

      cropRect = { x, y, w, h };
      renderImage();
    }
  });

  canvas.addEventListener('mouseup', () => {
    if (dragMode === 'creating' && cropRect.w < MIN_CROP_SIZE && cropRect.h < MIN_CROP_SIZE) {
      hasCrop = false;
      cropRect = { x: 0, y: 0, w: 0, h: 0 };
      renderImage();
    }
    dragMode = 'none';
  });

  canvas.addEventListener('mouseleave', () => {
    if (dragMode !== 'none') {
      dragMode = 'none';
      renderImage();
    }
  });

  // ===========================================================================
  // TOUCH EVENTS (móvil)
  // ===========================================================================

  canvas.addEventListener('touchstart', (e) => {
    e.preventDefault();
    const touch = e.touches[0];
    const pos = getCanvasPos(touch);

    if (isCropping && hasCrop) {
      const mode = getInteractionMode(pos);
      if (mode !== 'none') {
        dragMode = mode;
        dragStartX = pos.x;
        dragStartY = pos.y;
        dragOrigRect = { ...cropRect };
        return;
      }
    }

    if (isCropping) {
      dragMode = 'creating';
      dragStartX = pos.x;
      dragStartY = pos.y;
      cropRect = { x: pos.x, y: pos.y, w: 0, h: 0 };
      hasCrop = true;
    }
  }, { passive: false });

  canvas.addEventListener('touchmove', (e) => {
    e.preventDefault();
    const touch = e.touches[0];
    const pos = getCanvasPos(touch);

    if (dragMode === 'creating') {
      let nx = Math.min(dragStartX, pos.x);
      let ny = Math.min(dragStartY, pos.y);
      let nw = Math.abs(pos.x - dragStartX);
      let nh = Math.abs(pos.y - dragStartY);
      if (nw < MIN_CROP_SIZE) nw = MIN_CROP_SIZE;
      if (nh < MIN_CROP_SIZE) nh = MIN_CROP_SIZE;
      cropRect = { x: nx, y: ny, w: nw, h: nh };
      hasCrop = true;
      renderImage();
      return;
    }

    if (dragMode === 'moving') {
      const dx = pos.x - dragStartX;
      const dy = pos.y - dragStartY;
      let nx = dragOrigRect.x + dx;
      let ny = dragOrigRect.y + dy;
      nx = Math.max(0, Math.min(nx, canvas.width - cropRect.w));
      ny = Math.max(0, Math.min(ny, canvas.height - cropRect.h));
      cropRect.x = nx;
      cropRect.y = ny;
      renderImage();
      return;
    }

    if (dragMode.startsWith('resize-')) {
      const dx = pos.x - dragStartX;
      const dy = pos.y - dragStartY;
      let { x, y, w, h } = dragOrigRect;

      switch (dragMode) {
        case 'resize-tl':
          x = dragOrigRect.x + dx; y = dragOrigRect.y + dy;
          w = dragOrigRect.w - dx; h = dragOrigRect.h - dy;
          break;
        case 'resize-tr':
          y = dragOrigRect.y + dy;
          w = dragOrigRect.w + dx; h = dragOrigRect.h - dy;
          break;
        case 'resize-bl':
          x = dragOrigRect.x + dx;
          w = dragOrigRect.w - dx; h = dragOrigRect.h + dy;
          break;
        case 'resize-br':
          w = dragOrigRect.w + dx; h = dragOrigRect.h + dy;
          break;
      }

      if (w < MIN_CROP_SIZE) w = MIN_CROP_SIZE;
      if (h < MIN_CROP_SIZE) h = MIN_CROP_SIZE;
      if (w < 0) { x = x + w; w = Math.abs(w); }
      if (h < 0) { y = y + h; h = Math.abs(h); }
      x = Math.max(0, x);
      y = Math.max(0, y);
      if (x + w > canvas.width) w = canvas.width - x;
      if (y + h > canvas.height) h = canvas.height - y;

      cropRect = { x, y, w, h };
      renderImage();
    }
  }, { passive: false });

  canvas.addEventListener('touchend', () => {
    if (dragMode === 'creating' && cropRect.w < MIN_CROP_SIZE && cropRect.h < MIN_CROP_SIZE) {
      hasCrop = false;
      cropRect = { x: 0, y: 0, w: 0, h: 0 };
      renderImage();
    }
    dragMode = 'none';
  });

  // ===========================================================================
  // CONTROLES: BRILLO
  // ===========================================================================

  brightnessSlider?.addEventListener('input', () => {
    currentBrightness = parseInt(brightnessSlider.value);
    brightnessValue.textContent = currentBrightness.toString();
    renderImage();
  });

  // ===========================================================================
  // FUNCIÓN: Hornear rotación en la imagen (bake)
  // Toma la imagen actual, la rota en un canvas, y reemplaza originalImage
  // con el resultado. Así el recorte siempre trabaja sobre la imagen ya rotada.
  // ===========================================================================

  function bakeRotation(degrees: number) {
    if (!originalImage) return;

    const srcW = originalImage.width;
    const srcH = originalImage.height;
    const isRotated = degrees % 180 !== 0;
    const dstW = isRotated ? srcH : srcW;
    const dstH = isRotated ? srcW : srcH;

    const tempCanvas = document.createElement('canvas');
    tempCanvas.width = dstW;
    tempCanvas.height = dstH;
    const tempCtx = tempCanvas.getContext('2d')!;

    tempCtx.save();
    tempCtx.translate(dstW / 2, dstH / 2);
    tempCtx.rotate((degrees * Math.PI) / 180);
    tempCtx.drawImage(originalImage, -srcW / 2, -srcH / 2);
    tempCtx.restore();

    // Reemplazar originalImage con la imagen rotada
    const newImg = new Image();
    newImg.onload = () => {
      originalImage = newImg;
      currentRotation = 0; // ya no hay rotación pendiente
      hasCrop = false;
      cropRect = { x: 0, y: 0, w: 0, h: 0 };
      renderImage();
    };
    newImg.src = tempCanvas.toDataURL('image/jpeg', 0.95);
  }

  // ===========================================================================
  // CONTROLES: ROTACIÓN
  // ===========================================================================

  rotateLeftBtn?.addEventListener('click', () => {
    bakeRotation(-90);
  });

  rotateRightBtn?.addEventListener('click', () => {
    bakeRotation(90);
  });

  // ===========================================================================
  // CONTROLES: RECORTE
  // ===========================================================================

  cropToggleBtn?.addEventListener('click', () => {
    isCropping = !isCropping;
    if (isCropping) {
      cropBtnText.textContent = '✕ Desactivar Recorte';
      cropToggleBtn.className = 'px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg transition-base flex items-center gap-2';
      resetCropBtn.disabled = false;
      // Mostrar instrucciones temporalmente
      cropInstructions.classList.remove('opacity-0');
      setTimeout(() => cropInstructions.classList.add('opacity-0'), 4000);
    } else {
      cropBtnText.textContent = 'Activar Recorte';
      cropToggleBtn.className = 'px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg transition-base flex items-center gap-2';
      hasCrop = false;
      cropRect = { x: 0, y: 0, w: 0, h: 0 };
      resetCropBtn.disabled = true;
    }
    renderImage();
  });

  resetCropBtn?.addEventListener('click', () => {
    hasCrop = false;
    cropRect = { x: 0, y: 0, w: 0, h: 0 };
    resetCropBtn.disabled = true;
    renderImage();
  });

  // ===========================================================================
  // RESTABLECER TODO
  // ===========================================================================

  resetBtn?.addEventListener('click', () => {
    if (!baseImage) return;
    // Restaurar desde la imagen original inalterable
    const newImg = new Image();
    newImg.onload = () => {
      originalImage = newImg;
      currentRotation = 0;
      currentBrightness = 0;
      isCropping = false;
      hasCrop = false;
      cropRect = { x: 0, y: 0, w: 0, h: 0 };
      brightnessSlider.value = '0';
      brightnessValue.textContent = '0';
      cropBtnText.textContent = 'Activar Recorte';
      cropToggleBtn.className = 'px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg transition-base flex items-center gap-2';
      resetCropBtn.disabled = true;
      renderImage();
    };
    newImg.src = baseImage.src;
  });

  // ===========================================================================
  // APLICAR CAMBIOS - Exportar imagen editada como Base64
  // ===========================================================================

  applyBtn?.addEventListener('click', () => {
    if (!originalImage) return;

    const finalCanvas = document.createElement('canvas');
    const finalCtx = finalCanvas.getContext('2d')!;

    // La imagen ya está rotada (bake), currentRotation siempre es 0.
    // Solo necesitamos calcular la escala del canvas de preview a la imagen real.
    const maxWidth = 700, maxHeight = 550;
    const imgW = originalImage.width;
    const imgH = originalImage.height;
    let scale = 1;
    if (imgW > maxWidth) scale = maxWidth / imgW;
    if (imgH * scale > maxHeight) scale = maxHeight / imgH;

    if (isCropping && hasCrop && cropRect.w > 0 && cropRect.h > 0) {
      // Convertir coordenadas del recorte del canvas a la imagen original
      const cropX = Math.round(cropRect.x / scale);
      const cropY = Math.round(cropRect.y / scale);
      const cropW = Math.round(cropRect.w / scale);
      const cropH = Math.round(cropRect.h / scale);

      finalCanvas.width = cropW;
      finalCanvas.height = cropH;

      // Recortar directamente de la imagen ya rotada
      finalCtx.filter = `brightness(${1 + currentBrightness / 100})`;
      finalCtx.drawImage(originalImage, cropX, cropY, cropW, cropH, 0, 0, cropW, cropH);
      finalCtx.filter = 'none';
    } else {
      // Sin recorte: imagen completa con brillo
      finalCanvas.width = imgW;
      finalCanvas.height = imgH;

      finalCtx.filter = `brightness(${1 + currentBrightness / 100})`;
      finalCtx.drawImage(originalImage, 0, 0);
      finalCtx.filter = 'none';
    }

    // Exportar como JPEG comprimido
    const compressedBase64 = finalCanvas.toDataURL('image/jpeg', 0.9);

    // Cerrar editor
    editor.classList.add('hidden');
    const resolve = (window as any)._editorResolve;
    if (resolve) {
      resolve(compressedBase64);
      (window as any)._editorResolve = null;
    }
  });

  // ===========================================================================
  // CERRAR SIN APLICAR
  // ===========================================================================

  closeBtn?.addEventListener('click', () => {
    editor.classList.add('hidden');
    const resolve = (window as any)._editorResolve;
    if (resolve) {
      resolve(null); // null = cancelado
      (window as any)._editorResolve = null;
    }
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !editor.classList.contains('hidden')) {
      closeBtn?.click();
    }
  });

  // Exponer función globalmente
  (window as any).openImageEditor = openEditor;
   