// =============================================================================
// CHAT MODAL - Chat interno entre miembros de un Estok
// Botón amarillo en forma de sobre en la barra superior
//
// SEGURIDAD ANTI-FORENSE:
// - Botón de purga (escoba) que sobrescribe RAM con 0x00 y limpia UI
// - Burbuja roja de notificaciones se autoelimina al abrir el chat
// - Sin persistencia de mensajes en localStorage/sessionStorage
// - Jitter aleatorio en polling para romper patrones de tráfico
// =============================================================================
---

<div id="chatContainer" class="fixed bottom-4 right-4 z-50 flex flex-col items-end gap-2">
  <!-- Ventana de chat -->
  <div id="chatWindow" class="hidden bg-white rounded-2xl shadow-2xl border border-gray-200 w-80 sm:w-96 max-h-[500px] flex flex-col overflow-hidden transition-all duration-300 ease-out">
    <!-- Header del chat con botón de purga (escoba) -->
    <div class="flex items-center justify-between px-4 py-3 bg-yellow-400 border-b border-yellow-500">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-yellow-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <span id="chatTitle" class="text-sm font-bold text-yellow-900">Chat del Estok</span>
      </div>
      <div class="flex items-center gap-1">
        <!-- Botón de PURGA INMEDIATA (escoba) - Kill Switch -->
        <button id="chatPurgeBtn"
          class="p-1.5 rounded-lg hover:bg-red-500 hover:text-white transition-all duration-200 text-yellow-900 opacity-60 hover:opacity-100"
          title="Purga inmediata - Limpiar todo rastro de mensajes">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
        </button>
        <button id="chatCloseBtn" class="p-1 rounded-lg hover:bg-yellow-500 transition-base text-yellow-900">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mensajes -->
    <div id="chatMessages" class="flex-1 overflow-y-auto p-3 space-y-3 bg-gray-50" style="min-height: 250px; max-height: 350px;">
      <div class="text-center text-sm text-gray-400 py-8">
        <svg class="w-8 h-8 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <p>Cargando mensajes...</p>
      </div>
    </div>

    <!-- Input -->
    <div class="border-t border-gray-200 p-3 bg-white">
      <form id="chatForm" class="flex gap-2">
        <input
          id="chatInput"
          type="text"
          placeholder="Escribí un mensaje..."
          class="flex-1 px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-400 focus:border-yellow-400 outline-none"
          autocomplete="off"
        />
        <button
          id="chatSendBtn"
          type="submit"
          class="px-3 py-2 bg-yellow-400 text-yellow-900 font-medium rounded-lg hover:bg-yellow-500 transition-base shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </form>
    </div>
  </div>

  <!-- Botón flotante (sobre amarillo) -->
  <button id="chatToggleBtn"
    class="w-12 h-12 bg-yellow-400 hover:bg-yellow-500 rounded-full shadow-lg flex items-center justify-center transition-all duration-200 hover:scale-110 active:scale-95 relative"
    title="Chat del Estok">
    <svg class="w-6 h-6 text-yellow-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
    <!-- Badge de no leídos - se oculta automáticamente al abrir el chat -->
    <span id="chatUnreadBadge" class="hidden absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-xs font-bold rounded-full flex items-center justify-center shadow-sm">0</span>
  </button>
</div>

<script>
  import { fetchMensajes, enviarMensaje, fetchNoLeidos, purgeMensajes } from '../services/chat';
  import { getEstokActivoId } from '../services/auth';

  // ===========================================================================
  // ELEMENTOS DEL DOM
  // ===========================================================================

  const chatToggleBtn = document.getElementById('chatToggleBtn')!;
  const chatWindow = document.getElementById('chatWindow')!;
  const chatCloseBtn = document.getElementById('chatCloseBtn')!;
  const chatPurgeBtn = document.getElementById('chatPurgeBtn') as HTMLButtonElement;
  const chatMessages = document.getElementById('chatMessages')!;
  const chatForm = document.getElementById('chatForm') as HTMLFormElement;
  const chatInput = document.getElementById('chatInput') as HTMLInputElement;
  const chatSendBtn = document.getElementById('chatSendBtn') as HTMLButtonElement;
  const chatUnreadBadge = document.getElementById('chatUnreadBadge')!;
  const chatTitle = document.getElementById('chatTitle')!;

  // ===========================================================================
  // ESTADO
  // ===========================================================================

  let isOpen = false;
  let pollingInterval: number | null = null;
  let currentUserId: string | null = null;
  // Cache de colores por usuario para mantener consistencia en la sesión
  const userColors: Record<string, string> = {};

  // Paleta de colores para mensajes de otros usuarios (excluye amarillo que es para mensajes propios)
  const COLOR_PALETTE = [
    { bg: 'bg-blue-100', text: 'text-blue-900', border: 'border-blue-200', name: 'text-blue-600' },
    { bg: 'bg-green-100', text: 'text-green-900', border: 'border-green-200', name: 'text-green-600' },
    { bg: 'bg-purple-100', text: 'text-purple-900', border: 'border-purple-200', name: 'text-purple-600' },
    { bg: 'bg-pink-100', text: 'text-pink-900', border: 'border-pink-200', name: 'text-pink-600' },
    { bg: 'bg-indigo-100', text: 'text-indigo-900', border: 'border-indigo-200', name: 'text-indigo-600' },
    { bg: 'bg-teal-100', text: 'text-teal-900', border: 'border-teal-200', name: 'text-teal-600' },
    { bg: 'bg-orange-100', text: 'text-orange-900', border: 'border-orange-200', name: 'text-orange-600' },
    { bg: 'bg-cyan-100', text: 'text-cyan-900', border: 'border-cyan-200', name: 'text-cyan-600' },
  ];

  // Obtener usuario actual
  try {
    const userData = localStorage.getItem('estok_user');
    if (userData) {
      currentUserId = JSON.parse(userData).id;
    }
  } catch {}

  // ===========================================================================
  // FUNCIÓN PARA ASIGNAR COLOR CONSISTENTE POR USUARIO
  // ===========================================================================

  function getColorForUser(userId: string): typeof COLOR_PALETTE[0] {
    if (!userColors[userId]) {
      // Hash simple del userId para asignar color determinístico
      let hash = 0;
      for (let i = 0; i < userId.length; i++) {
        hash = ((hash << 5) - hash) + userId.charCodeAt(i);
        hash |= 0;
      }
      const index = Math.abs(hash) % COLOR_PALETTE.length;
      userColors[userId] = JSON.stringify(COLOR_PALETTE[index]);
    }
    return JSON.parse(userColors[userId]);
  }

  // ===========================================================================
  // ACTUALIZAR TÍTULO DEL CHAT SEGÚN EL ESTOK ACTIVO
  // ===========================================================================

  function updateChatTitle() {
    try {
      const userData = localStorage.getItem('estok_user');
      if (!userData) return;
      const user = JSON.parse(userData);
      const estokActivoId = getEstokActivoId();
      if (!estokActivoId || !user.estoks) return;
      const estokActivo = user.estoks.find((e: any) => e.id === estokActivoId);
      if (estokActivo) {
        chatTitle.textContent = `Chat del ${estokActivo.nombre}`;
      } else {
        chatTitle.textContent = 'Chat del Estok';
      }
    } catch {
      chatTitle.textContent = 'Chat del Estok';
    }
  }

  // ===========================================================================
  // FUNCIONES
  // ===========================================================================

  function getRemitenteNombre(msg: any): string {
    return msg.remitente_nombre || msg.remitente_username || 'Usuario';
  }

  function formatTime(dateStr: string): string {
    const d = new Date(dateStr);
    return d.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' });
  }

  function renderMensajes(mensajes: any[]) {
    if (mensajes.length === 0) {
      chatMessages.innerHTML = `
        <div class="text-center text-sm text-gray-400 py-8">
          <svg class="w-8 h-8 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <p>No hay mensajes aún.</p>
          <p class="text-xs text-gray-300 mt-1">¡Sé el primero en escribir!</p>
        </div>
      `;
      return;
    }

    // Ordenar por created_at ascendente (más antiguo primero, más nuevo al final)
    const ordenados = [...mensajes].sort((a, b) =>
      new Date(a.created_at).getTime() - new Date(b.created_at).getTime()
    );

    chatMessages.innerHTML = ordenados.map(msg => {
      const esPropio = msg.remitente === currentUserId;
      const nombre = getRemitenteNombre(msg);

      if (esPropio) {
        // Mensaje propio: siempre amarillo
        return `
          <div class="flex justify-end">
            <div class="max-w-[80%] bg-yellow-400 text-yellow-900 rounded-2xl px-3 py-2 shadow-sm">
              <p class="text-sm">${escapeHtml(msg.contenido)}</p>
              <p class="text-xs text-yellow-800 text-right mt-0.5">${formatTime(msg.created_at)}</p>
            </div>
          </div>
        `;
      } else {
        // Mensaje de otro usuario: color único por usuario
        const colors = getColorForUser(msg.remitente);
        return `
          <div class="flex justify-start">
            <div class="max-w-[80%] ${colors.bg} ${colors.text} border ${colors.border} rounded-2xl px-3 py-2 shadow-sm">
              <p class="text-xs font-semibold ${colors.name} mb-0.5">${escapeHtml(nombre)}</p>
              <p class="text-sm">${escapeHtml(msg.contenido)}</p>
              <p class="text-xs ${colors.text} opacity-60 text-right mt-0.5">${formatTime(msg.created_at)}</p>
            </div>
          </div>
        `;
      }
    }).join('');

    // Scroll al último mensaje
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // ===========================================================================
  // PURGA INMEDIATA (KILL SWITCH) - Escoba
  // Sobrescribe TODAS las variables en RAM con 0x00 y limpia la UI
  // ===========================================================================

  function stopAllPolling() {
    // Detener timer con jitter
    if ((window as any).__jitterTimer) {
      clearTimeout((window as any).__jitterTimer);
      (window as any).__jitterTimer = null;
    }
    // Detener setInterval legacy
    if (pollingInterval) {
      clearInterval(pollingInterval);
      pollingInterval = null;
    }
  }

  async function purgeChat() {
    // PURGA TOTAL: Elimina TODOS los mensajes del backend (base de datos)
    // y limpia la UI local. No queda ningún rastro en el servidor.

    // 1. Deshabilitar botón mientras se purga
    chatPurgeBtn.disabled = true;
    chatPurgeBtn.innerHTML = `
      <svg class="w-4 h-4 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    `;

    try {
      // 2. Llamar al endpoint de purga en el backend (DELETE /api/mensajes/purge/)
      const estokId = getEstokActivoId();
      const result = await purgeMensajes(estokId || undefined);

      // 3. Limpiar UI local
      const mensajesContainer = chatMessages;

      // 4. Sobrescribir el innerHTML con null bytes para limpiar búferes del DOM
      mensajesContainer.innerHTML = '\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00';

      // 5. Forzar reflow del navegador para limpiar búferes gráficos
      void mensajesContainer.offsetHeight;

      // 6. Limpiar el array de mensajes en memoria
      if ((window as any).__mensajesCache) {
        const len = (window as any).__mensajesCache.length;
        for (let i = 0; i < len; i++) {
          (window as any).__mensajesCache[i] = null;
        }
        (window as any).__mensajesCache = null;
      }

      // 7. Mostrar chat vacío con confirmación
      mensajesContainer.innerHTML = `
        <div class="text-center text-sm text-green-600 py-8">
          <svg class="w-10 h-10 mx-auto mb-2 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="font-semibold">Chat purgado</p>
          <p class="text-xs text-green-500 mt-1">${result.eliminados} mensajes eliminados permanentemente</p>
        </div>
      `;

      // 8. Forzar reflow
      void mensajesContainer.offsetHeight;

      // 9. Feedback visual (flash rojo rápido)
      mensajesContainer.style.transition = 'background-color 0.1s';
      mensajesContainer.style.backgroundColor = '#ff0000';
      setTimeout(() => {
        mensajesContainer.style.backgroundColor = '';
      }, 100);

      // 10. Limpiar el input
      chatInput.value = '';

      // 11. Ocultar badge de no leídos
      hideUnreadBadge();

    } catch (err: any) {
      // Si hay error (ej: no es Admin), mostrar mensaje de error
      const mensajesContainer = chatMessages;
      mensajesContainer.innerHTML = `
        <div class="text-center text-sm text-red-500 py-8">
          <svg class="w-10 h-10 mx-auto mb-2 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          <p class="font-semibold">Error al purgar</p>
          <p class="text-xs text-red-400 mt-1">${escapeHtml(err.message || 'Solo un Admin del Estok puede purgar el chat')}</p>
        </div>
      `;
    } finally {
      // 12. Restaurar botón
      chatPurgeBtn.disabled = false;
      chatPurgeBtn.innerHTML = `
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
      `;
    }
  }

  // ===========================================================================
  // BURBUJA ROJA - Se oculta automáticamente al abrir el chat
  // ===========================================================================

  function hideUnreadBadge() {
    chatUnreadBadge.classList.add('hidden');
    chatUnreadBadge.textContent = '0';
  }

  async function updateUnreadBadge() {
    try {
      const estokId = getEstokActivoId();
      if (!estokId) {
        chatUnreadBadge.classList.add('hidden');
        return;
      }
      // Si el chat está abierto, no mostrar badge (ya se vieron los mensajes)
      if (isOpen) {
        hideUnreadBadge();
        return;
      }
      const count = await fetchNoLeidos(estokId);
      if (count > 0) {
        chatUnreadBadge.textContent = count > 99 ? '99+' : String(count);
        chatUnreadBadge.classList.remove('hidden');
      } else {
        chatUnreadBadge.classList.add('hidden');
      }
    } catch {
      chatUnreadBadge.classList.add('hidden');
    }
  }

  // ===========================================================================
  // JITTER ALEATORIO PARA ROMPER PATRONES DE TRÁFICO
  // ===========================================================================

  function getJitteredInterval(baseMs: number): number {
    // Añade ±30% de jitter aleatorio al intervalo base
    const jitter = baseMs * 0.3;
    return baseMs + (Math.random() * jitter * 2 - jitter);
  }

  function scheduleWithJitter(fn: () => void, baseMs: number) {
    const delay = getJitteredInterval(baseMs);
    return window.setTimeout(() => {
      fn();
      // Re-schedule con nuevo jitter
      if (isOpen) {
        scheduleWithJitter(fn, baseMs);
      }
    }, delay);
  }

  // ===========================================================================
  // CARGA DE MENSAJES
  // ===========================================================================

  async function loadMensajes() {
    try {
      const estokId = getEstokActivoId();
      if (!estokId) return;
      const mensajes = await fetchMensajes(estokId);
      // Cache temporal para posible purga
      (window as any).__mensajesCache = mensajes;
      renderMensajes(mensajes);
    } catch (err) {
      console.error('Error al cargar mensajes:', err);
      chatMessages.innerHTML = `
        <div class="text-center text-sm text-red-400 py-8">
          <svg class="w-8 h-8 mx-auto mb-2 text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          <p>Error al cargar mensajes</p>
          <p class="text-xs text-red-300 mt-1">Intenta recargar la página</p>
        </div>
      `;
    }
  }

  function openChat() {
    isOpen = true;
    chatWindow.classList.remove('hidden');
    chatToggleBtn.classList.add('hidden');

    // OCULTAR BURBUJA ROJA INMEDIATAMENTE al abrir el chat
    hideUnreadBadge();

    updateChatTitle();
    loadMensajes();

    // Iniciar polling con JITTER ALEATORIO para romper patrones de tráfico
    if (pollingInterval) clearInterval(pollingInterval);
    pollingInterval = null;

    // Usar setTimeout recursivo con jitter en vez de setInterval fijo
    let jitterTimer: number;
    function jitteredPoll() {
      if (!isOpen) return;
      loadMensajes();
      updateUnreadBadge();
      jitterTimer = window.setTimeout(jitteredPoll, getJitteredInterval(5000));
    }
    jitterTimer = window.setTimeout(jitteredPoll, getJitteredInterval(5000));
    (window as any).__jitterTimer = jitterTimer;
  }

  function closeChat() {
    isOpen = false;
    chatWindow.classList.add('hidden');
    chatToggleBtn.classList.remove('hidden');

    // Limpiar timers
    if ((window as any).__jitterTimer) {
      clearTimeout((window as any).__jitterTimer);
      (window as any).__jitterTimer = null;
    }
    if (pollingInterval) {
      clearInterval(pollingInterval);
      pollingInterval = null;
    }

    // Al cerrar, la burbuja roja debe permanecer oculta
    // (ya se vieron los mensajes, no resurgir)
    hideUnreadBadge();
  }

  async function handleSend(e: Event) {
    e.preventDefault();
    const texto = chatInput.value.trim();
    if (!texto) return;

    chatSendBtn.disabled = true;
    chatInput.disabled = true;

    try {
      const estokId = getEstokActivoId();
      await enviarMensaje(texto, estokId || undefined);
      chatInput.value = '';
      await loadMensajes();
    } catch (err: any) {
      (window as any).showError?.(err.message || 'Error al enviar mensaje');
    } finally {
      chatSendBtn.disabled = false;
      chatInput.disabled = false;
      chatInput.focus();
    }
  }

  // ===========================================================================
  // EVENT LISTENERS
  // ===========================================================================

  chatToggleBtn.addEventListener('click', openChat);
  chatCloseBtn.addEventListener('click', closeChat);
  chatPurgeBtn.addEventListener('click', purgeChat);
  chatForm.addEventListener('submit', handleSend);

  // Enter para enviar
  chatInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      chatForm.dispatchEvent(new Event('submit'));
    }
  });

  // ===========================================================================
  // INICIALIZAR
  // ===========================================================================

  // Actualizar badge de no leídos con jitter aleatorio
  updateUnreadBadge();
  setInterval(updateUnreadBadge, getJitteredInterval(10000));

  // Escuchar cambios de Estok activo
  window.addEventListener('estok-changed', () => {
    // 1. Limpiar el contenedor de mensajes INMEDIATAMENTE para evitar
    //    que se vean mensajes del Estok anterior durante la transición
    chatMessages.innerHTML = `
      <div class="text-center text-sm text-gray-400 py-8">
        <svg class="w-8 h-8 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <p>Cargando mensajes...</p>
      </div>
    `;

    // 2. Actualizar título y badge
    updateChatTitle();
    updateUnreadBadge();

    // 3. Si el chat está abierto, recargar mensajes del nuevo Estok
    if (isOpen) {
      loadMensajes();
    }
  });

  // Escuchar evento para abrir desde el botón de la navbar
  window.addEventListener('open-chat', () => {
    openChat();
  });
</script>
